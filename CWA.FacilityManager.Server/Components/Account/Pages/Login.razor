@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using CWA.FacilityManager.Application.Interfaces
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Server.Services

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IUserProfileService UserProfileService
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IRoleBasedRedirectService RoleBasedRedirectService

<PageTitle>Log in</PageTitle>

<h1>Log in</h1>
<div class="row">
    <div class="col-lg-6">
        <section>
            <StatusMessage Message="@errorMessage" />
            <!-- Account Deactivated Warning -->
            @if (!string.IsNullOrEmpty(deactivatedMessage))
            {
                <div class="alert alert-warning deactivation-notice security-notice" role="alert">
                    <h4 class="alert-heading">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Account Deactivated
                    </h4>
                    <p class="mb-0">@deactivatedMessage</p>
                    <hr>
                    <div class="contact-info">
                        <p class="mb-0">
                            <strong>Next Steps:</strong>
                        </p>
                        <ul class="next-steps mt-2 mb-0">
                            <li>Contact your system administrator or staff member</li>
                            <li>Provide your email address: <strong>@deactivatedUserEmail</strong></li>
                            <li>Ask for account reactivation if this was done in error</li>
                        </ul>
                    </div>
                </div>
            }
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login" class="@(string.IsNullOrEmpty(deactivatedMessage) ? "" : "login-form-disabled")">
                <DataAnnotationsValidator />
                <h2>Use a local account to log in.</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" disabled="@(!string.IsNullOrEmpty(deactivatedMessage))" />
                    <label for="Input.Email" class="form-label">Email</label>
                    <ValidationMessage For="() => Input.Email" class="text-danger" />
                </div>
                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" disabled="@(!string.IsNullOrEmpty(deactivatedMessage))" />
                    <label for="Input.Password" class="form-label">Password</label>
                    <ValidationMessage For="() => Input.Password" class="text-danger" />
                </div>
                <div class="checkbox mb-3">
                    <label class="form-label">
                        <InputCheckbox @bind-Value="Input.RememberMe" class="darker-border-checkbox form-check-input" disabled="@(!string.IsNullOrEmpty(deactivatedMessage))" />
                        Remember me
                    </label>
                </div>
                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@(!string.IsNullOrEmpty(deactivatedMessage))">
                        @if (!string.IsNullOrEmpty(deactivatedMessage))
                        {
                            <i class="bi bi-lock-fill me-2"></i><span>Account Deactivated - Login Disabled</span>
                        }
                        else
                        {
                            <span>Log in</span>
                        }
                    </button>
                </div>
                <div>
                    <p>
                        <a href="Account/ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Register as a new user</a>
                    </p>
                    <p>
                        <a href="Account/ResendEmailConfirmation">Resend email confirmation</a>
                    </p>
                </div>
            </EditForm>
        </section>
    </div>
    <div class="col-lg-4 col-lg-offset-2">
        <section>
            <h3>Use another service to log in.</h3>
            <hr />
            <ExternalLoginPicker />
        </section>
    </div>
</div>

@code {
    private string? errorMessage;
    private string? deactivatedMessage;
    private string? deactivatedUserEmail;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        // Clear previous messages
        errorMessage = null;
        deactivatedMessage = null;
        deactivatedUserEmail = null;

        // First, check if the user exists and verify their credentials
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user != null)
        {
            // Check if the user is deactivated BEFORE attempting sign-in
            if (!user.IsActive)
            {
                deactivatedMessage = "Your account has been deactivated by a staff member. This means you cannot log in until your account is reactivated.";
                deactivatedUserEmail = Input.Email;
                Logger.LogWarning("Deactivated user attempted to login: {Email}", Input.Email);
                return;
            }

            // Check password validity before proceeding
            var passwordValid = await UserManager.CheckPasswordAsync(user, Input.Password);
            if (!passwordValid)
            {
                errorMessage = "Error: Invalid login attempt.";
                return;
            }
        }

        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in: {Email}", Input.Email);

            // Update last login time and log the activity
            try
            {
                if (user != null)
                {
                    user.LastLoginAt = DateTime.UtcNow;
                    await UserManager.UpdateAsync(user);
                    
                    // Log the login activity (from User-profile-history branch)
                    await UserProfileService.AddUserHistoryAsync(
                        user.Id, 
                        UserHistoryType.Login, 
                        "User logged in successfully",
                        $"Login from IP: {HttpContext.Connection.RemoteIpAddress}"
                    );

                    // Create claims principal to check user permissions for redirect (from Merge-Test branch)
                    var claimsPrincipal = await SignInManager.CreateUserPrincipalAsync(user);
                    
                    // Validate return URL based on user's roles
                    var validReturnUrl = await RoleBasedRedirectService.GetValidReturnUrlAsync(ReturnUrl, claimsPrincipal);
                    
                    Logger.LogInformation("User {Email} redirected to: {ReturnUrl}", Input.Email, validReturnUrl);
                    RedirectManager.RedirectTo(validReturnUrl);
                }
                else
                {
                    RedirectManager.RedirectTo(ReturnUrl);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error updating login information for user {Email}", Input.Email);
                // Don't fail login if history logging fails, but still redirect
                RedirectManager.RedirectTo(ReturnUrl);
            }
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out: {Email}", Input.Email);
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else if (result.IsNotAllowed)
        {
            Logger.LogWarning("User account not allowed to login - email not confirmed: {Email}", Input.Email);
            errorMessage = "Error: Email not confirmed. Please check your email and confirm your account before logging in.";
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}