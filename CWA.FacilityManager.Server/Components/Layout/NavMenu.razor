@implements IDisposable
@rendermode InteractiveServer

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CWA.FacilityManager</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu me-2" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView Context="mainAuth" Policy="ActiveUser">
            <Authorized>
                <!-- User Profile Section (from User-profile-history) -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="profile">
                        <span class="bi bi-person-circle-nav-menu me-2" aria-hidden="true"></span> My Profile
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="history">
                        <span class="bi bi-clock-history-nav-menu me-2" aria-hidden="true"></span> My History
                    </NavLink>
                </div>

                <!-- Basic Facility Access -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="rooms">
                        <span class="bi bi-door-open-nav-menu me-2" aria-hidden="true"></span> Rooms
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="events">
                        <span class="bi bi-calendar-event-nav-menu me-2" aria-hidden="true"></span> Events
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="bookings">
                        <span class="bi bi-calendar-check-nav-menu me-2" aria-hidden="true"></span> My Bookings
                    </NavLink>
                </div>

                <!-- Task Calendar (from Merge-Test) -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="calendar">
                        <span class="bi bi-calendar-nav-menu me-2" aria-hidden="true"></span> Task Calendar
                    </NavLink>
                </div>

                <!-- Administration Section -->
                <AuthorizeView Roles="Administrator,Secretary" Context="adminAuth" Policy="ActiveAdminOrSecretary">
                    <Authorized>
                        <div class="nav-item px-3 mt-3">
                            <div class="admin-menu-header nav-link text-light fw-bold border-bottom border-secondary mb-2"
                                 style="cursor: pointer; user-select: none;"
                                 @onclick="ToggleAdministration"
                                 @onclick:preventDefault="true">
                                <div class="d-flex align-items-center justify-content-between w-100">
                                    <div class="d-flex align-items-center">
                                        <span class="bi bi-gear-fill me-2" aria-hidden="true"></span>
                                        <span>Administration</span>
                                    </div>
                                    <span class="bi @(isAdministrationExpanded ? "bi-chevron-up" : "bi-chevron-down") dropdown-icon" aria-hidden="true"></span>
                                </div>
                            </div>
                        </div>

                        @if (isAdministrationExpanded)
                        {
                            <div class="admin-submenu">
                                <!-- User Management -->
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/users">
                                        <span class="bi bi-people-fill me-2" aria-hidden="true"></span>
                                        <span>User Management</span>
                                    </NavLink>
                                </div>

                                <!-- Role Management (Administrator only) -->
                                <AuthorizeView Roles="Administrator" Context="roleMgmtAuth" Policy="ActiveAdmin">
                                    <Authorized>
                                        <div class="nav-item px-3 ps-4">
                                            <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/roles">
                                                <span class="bi bi-shield-check me-2" aria-hidden="true"></span>
                                                <span>Role Management</span>
                                            </NavLink>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>

                <!-- Facility Management Section -->
                <AuthorizeView Roles="Administrator,Secretary" Context="facilityAuth" Policy="ActiveAdminOrSecretary">
                    <Authorized>
                        <div class="nav-item px-3 mt-3">
                            <div class="admin-menu-header nav-link text-light fw-bold border-bottom border-secondary mb-2"
                                 style="cursor: pointer; user-select: none;"
                                 @onclick="ToggleFacilityManagement"
                                 @onclick:preventDefault="true">
                                <div class="d-flex align-items-center justify-content-between w-100">
                                    <div class="d-flex align-items-center">
                                        <span class="bi bi-building-fill me-2" aria-hidden="true"></span>
                                        <span>Facility Management</span>
                                    </div>
                                    <span class="bi @(isFacilityManagementExpanded ? "bi-chevron-up" : "bi-chevron-down") dropdown-icon" aria-hidden="true"></span>
                                </div>
                            </div>
                        </div>

                        @if (isFacilityManagementExpanded)
                        {
                            <div class="admin-submenu">
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/facilities">
                                        <span class="bi bi-building me-2" aria-hidden="true"></span>
                                        <span>Facilities</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/rooms">
                                        <span class="bi bi-door-open me-2" aria-hidden="true"></span>
                                        <span>Rooms</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/bookings">
                                        <span class="bi bi-calendar-check me-2" aria-hidden="true"></span>
                                        <span>Bookings</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/events">
                                        <span class="bi bi-calendar-event me-2" aria-hidden="true"></span>
                                        <span>Events</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item px-3 ps-4">
                                    <NavLink class="nav-link admin-nav-link d-flex align-items-center" href="admin/reports">
                                        <span class="bi bi-graph-up me-2" aria-hidden="true"></span>
                                        <span>Reports & Analytics</span>
                                    </NavLink>
                                </div>
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>

                <!-- Renter Quick Access -->
                <AuthorizeView Roles="Renter" Context="renterAuth" Policy="ActiveUser">
                    <Authorized>
                        <div class="nav-item px-3 mt-3 pt-3 border-top border-secondary">
                            <div class="text-light fw-bold mb-2">
                                <span class="bi bi-calendar-check me-2" aria-hidden="true"></span> Quick Access
                            </div>
                        </div>

                        <div class="nav-item px-3 ps-4 renter-only">
                            <NavLink class="nav-link" href="facilities">
                                <span class="bi bi-building me-2" aria-hidden="true"></span> Browse Facilities
                            </NavLink>
                        </div>

                        <div class="nav-item px-3 ps-4 renter-only">
                            <NavLink class="nav-link" href="bookings/my">
                                <span class="bi bi-calendar-check me-2" aria-hidden="true"></span> My Bookings
                            </NavLink>
                        </div>

                        <div class="nav-item px-3 ps-4 renter-only">
                            <NavLink class="nav-link" href="events/my">
                                <span class="bi bi-calendar-event me-2" aria-hidden="true"></span> My Events
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>

        <!-- Sample pages (kept for development) -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill-nav-menu me-2" aria-hidden="true"></span> Counter
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu me-2" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="auth">
                <span class="bi bi-lock-nav-menu me-2" aria-hidden="true"></span> Auth Required
            </NavLink>
        </div>

        <AuthorizeView Context="mainAuth" Policy="ActiveUser">
            <Authorized>
                <!-- Profile & Account -->
                <div class="nav-item px-3 mt-3 pt-3 border-top border-secondary">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu me-2" aria-hidden="true"></span> @mainAuth.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu me-2" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu me-2" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu me-2" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool isAdministrationExpanded = false;
    private bool isFacilityManagementExpanded = false;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        // Auto-expand menus based on initial location
        ExpandForCurrentUrl();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        ExpandForCurrentUrl();
        StateHasChanged();
    }

    private void ExpandForCurrentUrl()
    {
        if (string.IsNullOrEmpty(currentUrl))
            return;

        if (currentUrl.StartsWith("admin/users", StringComparison.OrdinalIgnoreCase) ||
            currentUrl.StartsWith("admin/roles", StringComparison.OrdinalIgnoreCase))
        {
            isAdministrationExpanded = true;
            isFacilityManagementExpanded = false;
        }
        else if (currentUrl.StartsWith("admin/facilities", StringComparison.OrdinalIgnoreCase) ||
                 currentUrl.StartsWith("admin/rooms", StringComparison.OrdinalIgnoreCase) ||
                 currentUrl.StartsWith("admin/bookings", StringComparison.OrdinalIgnoreCase) ||
                 currentUrl.StartsWith("admin/events", StringComparison.OrdinalIgnoreCase) ||
                 currentUrl.StartsWith("admin/reports", StringComparison.OrdinalIgnoreCase))
        {
            isFacilityManagementExpanded = true;
            isAdministrationExpanded = false;
        }
    }

    private void ToggleAdministration()
    {
        isAdministrationExpanded = !isAdministrationExpanded;
        if (isAdministrationExpanded)
            isFacilityManagementExpanded = false;
    }

    private void ToggleFacilityManagement()
    {
        isFacilityManagementExpanded = !isFacilityManagementExpanded;
        if (isFacilityManagementExpanded)
            isAdministrationExpanded = false;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}