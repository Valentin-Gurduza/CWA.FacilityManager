@using CWA.FacilityManager.Server.Components.Layout
@using CWA.FacilityManager.Server.Components.Account.Shared
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            <EmailConfirmationWarning />
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<!-- Add Authentication Status Checker for Security -->
<CWA.FacilityManager.Server.Components.AuthenticationStatusChecker />
