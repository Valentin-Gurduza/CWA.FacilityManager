@page "/rooms"
@rendermode InteractiveServer
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject IBookingService BookingService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Rooms Management</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="container-fluid">
            <!-- Header Section -->
            <div class="page-header mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="page-icon me-3">
                            <i class="fas fa-door-open"></i>
                        </div>
                        <div>
                            <h1 class="page-title mb-0">Rooms Management</h1>
                            <p class="page-subtitle mb-0">Browse and manage facility rooms</p>
                        </div>
                    </div>
                    <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="headerAdminContext">
                        <Authorized>
                            <button class="btn btn-primary btn-lg" @onclick="ShowAddRoomModal" type="button">
                                <i class="fas fa-plus me-2"></i> Add New Room
                            </button>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="row mb-4 g-4">
                <div class="col-md-4">
                    <div class="stat-card glass-effect">
                        <div class="stat-icon-wrapper primary">
                            <i class="fas fa-door-open"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">@(rooms?.Count() ?? 0)</h3>
                            <p class="stat-label">Total Rooms</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card glass-effect">
                        <div class="stat-icon-wrapper success">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">@(rooms?.Sum(r => r.Capacity) ?? 0)</h3>
                            <p class="stat-label">Total Capacity</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card glass-effect">
                        <div class="stat-icon-wrapper info">
                            <i class="fas fa-building"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">@(buildings?.Count() ?? 0)</h3>
                            <p class="stat-label">Buildings</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Messages -->
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="row mb-3">
                    <div class="col-12">
                        <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                            <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle") me-2"></i>
                            @statusMessage
                            <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                        </div>
                    </div>
                </div>
            }

            <!-- User Profile Integration Notice -->
            <AuthorizeView Roles="Renter" Policy="ActiveUser" Context="renterNoticeContext">
                <Authorized>
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="alert alert-info" role="alert">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-info-circle me-3 fs-4"></i>
                                    <div>
                                        <strong>Room Booking Information</strong>
                                        <p class="mb-0">
                                            Browse available rooms below. For booking history and profile management, 
                                            visit your <a href="/profile" class="alert-link">Profile</a> and 
                                            <a href="/history" class="alert-link">History</a> pages.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            <!-- Rooms Grid -->
            <div class="row g-4">
                @if (rooms == null)
                {
                    <div class="col-12 text-center py-5">
                        <div class="loading-spinner mx-auto mb-3"></div>
                        <p class="text-muted">Loading rooms...</p>
                    </div>
                }
                else if (!rooms.Any())
                {
                    <div class="col-12">
                        <div class="empty-state glass-effect text-center py-5">
                            <div class="empty-icon mb-4">
                                <i class="fas fa-door-open"></i>
                            </div>
                            <h4>No Rooms Available</h4>
                            <p class="text-muted">
                                <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="noRoomsAdminContext">
                                    <Authorized>Start by adding your first room to the system!</Authorized>
                                    <NotAuthorized>No rooms are currently available for booking. Please contact an administrator.</NotAuthorized>
                                </AuthorizeView>
                            </p>
                            <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="addFirstRoomContext">
                                <Authorized>
                                    <button class="btn btn-primary btn-lg" @onclick="ShowAddRoomModal" type="button">
                                        <i class="fas fa-plus me-2"></i> Add Your First Room
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var room in rooms)
                    {
                        <div class="col-xl-4 col-lg-6 col-md-6">
                            <div class="room-card glass-effect h-100">
                                <div class="room-card-header">
                                    <div class="room-title-section">
                                        <h5 class="room-name">@room.Name</h5>
                                        <span class="room-number">@room.RoomNumber</span>
                                    </div>
                                    <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="roomCardAdminContext">
                                        <Authorized>
                                            <div class="dropdown">
                                                <button class="btn btn-ghost btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li><button class="dropdown-item" @onclick="() => EditRoom(room)" type="button">
                                                        <i class="fas fa-edit me-2"></i> Edit
                                                    </button></li>
                                                    <li><button class="dropdown-item text-danger" @onclick="() => DeleteRoom(room)" type="button">
                                                        <i class="fas fa-trash me-2"></i> Delete
                                                    </button></li>
                                                </ul>
                                            </div>
                                        </Authorized>
                                    </AuthorizeView>
                                </div>
                                <div class="room-card-body">
                                    <div class="room-info-grid">
                                        <div class="room-info-item">
                                            <i class="fas fa-building"></i>
                                            <span>@room.Building?.Name</span>
                                        </div>
                                        <div class="room-info-item">
                                            <i class="fas fa-users"></i>
                                            <span>@room.Capacity people</span>
                                        </div>
                                        <div class="room-info-item">
                                            <i class="fas @GetActivityIcon(room.Activity)"></i>
                                            <span>@room.Activity</span>
                                        </div>
                                        <div class="room-info-item">
                                            <i class="fas fa-calendar"></i>
                                            <span>@room.Date.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="room-info-item">
                                            <i class="fas fa-clock"></i>
                                            <span>@room.Time.ToString(@"hh\:mm")</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(room.Description))
                                    {
                                        <p class="room-description">
                                            <i class="fas fa-info-circle me-1"></i>
                                            @room.Description
                                        </p>
                                    }
                                </div>
                                <div class="room-card-footer">
                                    <AuthorizeView Roles="Renter,Administrator,Secretary" Policy="ActiveUser" Context="bookButtonContext">
                                        <Authorized>
                                            <button class="btn btn-primary w-100" @onclick="() => ShowBookingModal(room)" type="button">
                                                <i class="fas fa-calendar-plus me-2"></i> Book Room
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Features Overview -->
            @if (rooms == null || !rooms.Any())
            {
                <div class="row mt-5">
                    <div class="col-12">
                        <div class="card glass-effect">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-star me-2"></i> Room Management Features</h5>
                            </div>
                            <div class="card-body">
                                <p>This platform provides comprehensive room management capabilities:</p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <ul class="feature-list">
                                            <li><i class="fas fa-check-circle"></i> Browse available rooms</li>
                                            <li><i class="fas fa-check-circle"></i> View room details and amenities</li>
                                            <li><i class="fas fa-check-circle"></i> Check room availability</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <ul class="feature-list">
                                            <li><i class="fas fa-check-circle"></i> Make room reservations</li>
                                            <li><i class="fas fa-check-circle"></i> Manage existing bookings</li>
                                            <li><i class="fas fa-check-circle"></i> Track booking history</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Add/Edit Room Modal -->
        <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="modalAdminContext">
            <Authorized>
                @if (showRoomModal)
                {
                    <div class="modal-backdrop fade show" @onclick="CloseModal"></div>
                    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content" @onclick:stopPropagation="true">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        <i class="fas @(isEditMode ? "fa-edit" : "fa-plus") me-2"></i>
                                        @(isEditMode ? "Edit Room" : "Add New Room")
                                    </h5>
                                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                                </div>
                                
                                <EditForm Model="roomModel" OnValidSubmit="SaveRoom" Context="editContext">
                                    <DataAnnotationsValidator />
                                    <div class="modal-body">
                                        <ValidationSummary class="alert alert-danger" role="alert" />
                                        
                                        <div class="mb-3">
                                            <label class="form-label">
                                                <i class="fas fa-tag me-1"></i>Room Name <span class="text-danger">*</span>
                                            </label>
                                            <InputText class="form-control" @bind-Value="roomModel.Name" 
                                                       placeholder="Enter room name" />
                                            <ValidationMessage For="() => roomModel.Name" class="text-danger small" />
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">
                                                <i class="fas fa-building me-1"></i>Building <span class="text-danger">*</span>
                                            </label>
                                            <InputText class="form-control" @bind-Value="buildingName" 
                                                       placeholder="Enter building name" list="buildingsList" />
                                            <datalist id="buildingsList">
                                                @if (buildings != null)
                                                {
                                                    @foreach (var building in buildings)
                                                    {
                                                        <option value="@building.Name"></option>
                                                    }
                                                }
                                            </datalist>
                                            <div class="form-text">Start typing to see suggestions</div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">
                                                <i class="fas fa-tasks me-1"></i>Activity Type <span class="text-danger">*</span>
                                            </label>
                                            <InputSelect class="form-select" @bind-Value="roomModel.Activity">
                                                <option value="@ActivityType.Course">Course</option>
                                                <option value="@ActivityType.Meeting">Meeting</option>
                                                <option value="@ActivityType.Training">Training</option>
                                            </InputSelect>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="fas fa-calendar me-1"></i>Date <span class="text-danger">*</span>
                                                    </label>
                                                    <InputDate class="form-control" @bind-Value="roomModel.Date" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="fas fa-clock me-1"></i>Time <span class="text-danger">*</span>
                                                    </label>
                                                    <InputText class="form-control" @bind-Value="timeInput" type="time" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="fas fa-door-open me-1"></i>Room Number
                                                    </label>
                                                    <InputText class="form-control" @bind-Value="roomModel.RoomNumber" 
                                                               placeholder="e.g., A101" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="fas fa-users me-1"></i>Capacity <span class="text-danger">*</span>
                                                    </label>
                                                    <InputNumber class="form-control" @bind-Value="roomModel.Capacity" min="1" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">
                                                <i class="fas fa-align-left me-1"></i>Description
                                            </label>
                                            <InputTextArea class="form-control" rows="3" @bind-Value="roomModel.Description" 
                                                           placeholder="Room description..." />
                                        </div>
                                    </div>
                                    
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                                            <i class="fas fa-times me-1"></i> Cancel
                                        </button>
                                        <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                            @if (isProcessing)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2"></span>
                                            }
                                            <i class="fas @(isEditMode ? "fa-save" : "fa-plus") me-1"></i>
                                            @(isEditMode ? "Update" : "Add Room")
                                        </button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Booking Modal -->
        @if (showBookingModal)
        {
            <div class="modal-backdrop fade show" @onclick="CloseBookingModal"></div>
            <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header modal-header-success">
                            <h5 class="modal-title">
                                <i class="fas fa-calendar-plus me-2"></i>
                                Book Room: @selectedRoom?.Name
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseBookingModal"></button>
                        </div>
                        
                        <EditForm Model="bookingModel" OnValidSubmit="CreateBooking" Context="bookingContext">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <ValidationSummary class="alert alert-danger" role="alert" />
                                
                                <div class="room-details-card mb-4">
                                    <h6><i class="fas fa-info-circle me-2"></i>Room Details</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p><strong>Room:</strong> @selectedRoom?.Name</p>
                                            <p><strong>Building:</strong> @selectedRoom?.Building?.Name</p>
                                        </div>
                                        <div class="col-md-6">
                                            <p><strong>Capacity:</strong> @selectedRoom?.Capacity people</p>
                                            <p><strong>Activity:</strong> @selectedRoom?.Activity</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-tag me-1"></i>Booking Title <span class="text-danger">*</span>
                                    </label>
                                    <InputText class="form-control" @bind-Value="bookingModel.Title" 
                                               placeholder="Enter booking title" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-align-left me-1"></i>Description
                                    </label>
                                    <InputTextArea class="form-control" rows="2" @bind-Value="bookingModel.Description" 
                                                   placeholder="Booking description..." />
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Start Date <span class="text-danger">*</span></label>
                                            <InputDate class="form-control" @bind-Value="startDate" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Start Time <span class="text-danger">*</span></label>
                                            <InputText class="form-control" @bind-Value="startTime" type="time" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">End Date <span class="text-danger">*</span></label>
                                            <InputDate class="form-control" @bind-Value="endDate" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">End Time <span class="text-danger">*</span></label>
                                            <InputText class="form-control" @bind-Value="endTime" type="time" />
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Expected Attendees</label>
                                    <InputNumber class="form-control" @bind-Value="bookingModel.AttendeeCount" 
                                                 min="1" max="@selectedRoom?.Capacity" />
                                    <div class="form-text">Maximum: @selectedRoom?.Capacity people</div>
                                </div>
                            </div>
                            
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseBookingModal">
                                    <i class="fas fa-times me-1"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-success" disabled="@isProcessing">
                                    @if (isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    <i class="fas fa-check me-1"></i> Create Booking
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="empty-state glass-effect text-center py-5 mt-5">
                        <div class="empty-icon mb-4">
                            <i class="fas fa-lock"></i>
                        </div>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need to be logged in to access the rooms management system.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt me-2"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Room>? rooms;
    private IEnumerable<Building>? buildings;
    private bool showRoomModal = false;
    private bool showBookingModal = false;
    private bool isEditMode = false;
    private bool isProcessing = false;
    private Room roomModel = new Room();
    private Booking bookingModel = new Booking();
    private Room? selectedRoom;
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private string buildingName = string.Empty;
    private string timeInput = "09:00";
    
    private DateTime startDate = DateTime.Today.AddDays(1);
    private DateTime endDate = DateTime.Today.AddDays(1);
    private string startTime = "09:00";
    private string endTime = "10:00";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            buildings = await BuildingService.GetAllBuildingsAsync();
            rooms = await RoomService.GetAllRoomsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading data: {ex.Message}", "error");
        }
    }

    private void ShowAddRoomModal()
    {
        roomModel = new Room { 
            Id = 0,
            Capacity = 1, 
            Activity = ActivityType.Course,
            Date = DateTime.Today,
            Time = TimeSpan.FromHours(9),
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };
        buildingName = string.Empty;
        timeInput = "09:00";
        isEditMode = false;
        showRoomModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void EditRoom(Room room)
    {
        roomModel = new Room();
        roomModel.Id = room.Id;
        roomModel.Name = room.Name;
        roomModel.RoomNumber = room.RoomNumber;
        roomModel.Capacity = room.Capacity;
        roomModel.Description = room.Description;
        roomModel.BuildingId = room.BuildingId;
        roomModel.Activity = room.Activity;
        roomModel.Date = room.Date;
        roomModel.Time = room.Time;
        roomModel.IsActive = room.IsActive;
        roomModel.CreatedAt = room.CreatedAt;
        
        buildingName = room.Building?.Name ?? string.Empty;
        timeInput = room.Time.ToString(@"hh\:mm");
        isEditMode = true;
        showRoomModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void CloseModal()
    {
        showRoomModal = false;
        roomModel = new Room();
        buildingName = string.Empty;
        timeInput = "09:00";
        isProcessing = false;
        isEditMode = false;
        StateHasChanged();
    }

    private async Task ShowBookingModal(Room room)
    {
        try
        {
            selectedRoom = room;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                ShowStatusMessage("User not authenticated. Please log in again.", "error");
                return;
            }

            bookingModel = new Booking
            {
                UserId = userId,
                RoomId = room.Id,
                Title = "",
                Description = "",
                AttendeeCount = 1,
                SpecialRequirements = "",
                Status = BookingStatus.Pending
            };
            
            startDate = DateTime.Today.AddDays(1);
            endDate = DateTime.Today.AddDays(1);
            startTime = "09:00";
            endTime = "10:00";
            
            showBookingModal = true;
            ClearStatusMessage();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error opening booking modal: {ex.Message}", "error");
        }
    }

    private void CloseBookingModal()
    {
        showBookingModal = false;
        selectedRoom = null;
        bookingModel = new Booking();
        isProcessing = false;
        StateHasChanged();
    }

    private async Task CreateBooking()
    {
        if (selectedRoom == null)
        {
            ShowStatusMessage("Room not selected.", "error");
            return;
        }

        if (string.IsNullOrWhiteSpace(bookingModel.Title))
        {
            ShowStatusMessage("Booking title is required.", "error");
            return;
        }

        if (string.IsNullOrEmpty(bookingModel.UserId))
        {
            ShowStatusMessage("User authentication expired. Please refresh the page.", "error");
            return;
        }

        if (!TimeSpan.TryParse(startTime, out var startTimeSpan) || !TimeSpan.TryParse(endTime, out var endTimeSpan))
        {
            ShowStatusMessage("Invalid time format.", "error");
            return;
        }

        var startDateTime = startDate.Date.Add(startTimeSpan);
        var endDateTime = endDate.Date.Add(endTimeSpan);

        if (startDateTime >= endDateTime)
        {
            ShowStatusMessage("End time must be after start time.", "error");
            return;
        }

        if (startDateTime <= DateTime.Now)
        {
            ShowStatusMessage("Booking must be scheduled for the future.", "error");
            return;
        }

        if (bookingModel.AttendeeCount.HasValue && bookingModel.AttendeeCount > selectedRoom.Capacity)
        {
            ShowStatusMessage($"Attendee count cannot exceed room capacity of {selectedRoom.Capacity}.", "error");
            return;
        }

        isProcessing = true;
        StateHasChanged();

        try
        {
            bookingModel.RoomId = selectedRoom.Id;
            bookingModel.StartDate = startDateTime;
            bookingModel.EndDate = endDateTime;
            bookingModel.Status = BookingStatus.Pending;

            var createdBooking = await BookingService.CreateBookingAsync(bookingModel);
            ShowStatusMessage($"Booking '{createdBooking.Title}' created successfully!", "success");
            CloseBookingModal();
        }
        catch (InvalidOperationException ex)
        {
            ShowStatusMessage($"Booking failed: {ex.Message}", "error");
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error creating booking: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SaveRoom()
    {
        if (string.IsNullOrWhiteSpace(roomModel.Name))
        {
            ShowStatusMessage("Room name is required.", "error");
            return;
        }

        if (string.IsNullOrWhiteSpace(buildingName))
        {
            ShowStatusMessage("Building name is required.", "error");
            return;
        }

        if (roomModel.Capacity <= 0)
        {
            ShowStatusMessage("Capacity must be greater than 0.", "error");
            return;
        }

        if (!TimeSpan.TryParse(timeInput, out var time))
        {
            ShowStatusMessage("Invalid time format.", "error");
            return;
        }
        roomModel.Time = time;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var existingBuilding = buildings?.FirstOrDefault(b => b.Name.Equals(buildingName, StringComparison.OrdinalIgnoreCase));
            if (existingBuilding != null)
            {
                roomModel.BuildingId = existingBuilding.Id;
            }
            else
            {
                var newBuilding = new Building 
                { 
                    Name = buildingName, 
                    Address = string.Empty,
                    Description = $"Auto-created building for {buildingName}",
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                };
                var createdBuilding = await BuildingService.CreateBuildingAsync(newBuilding);
                roomModel.BuildingId = createdBuilding.Id;
                buildings = await BuildingService.GetAllBuildingsAsync();
            }

            if (roomModel.BuildingId <= 0)
            {
                ShowStatusMessage("Unable to determine building ID.", "error");
                return;
            }

            if (isEditMode)
            {
                await RoomService.UpdateRoomAsync(roomModel);
                ShowStatusMessage($"Room '{roomModel.Name}' updated successfully!", "success");
            }
            else
            {
                roomModel.Id = 0;
                await RoomService.CreateRoomAsync(roomModel);
                ShowStatusMessage($"Room '{roomModel.Name}' created successfully!", "success");
            }
            
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error saving room: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteRoom(Room room)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete '{room.Name}'? This cannot be undone."))
        {
            try
            {
                var result = await RoomService.DeleteRoomAsync(room.Id);
                if (result)
                {
                    ShowStatusMessage($"Room '{room.Name}' deleted!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to delete room.", "error");
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error: {ex.Message}", "error");
            }
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        if (type == "success")
        {
            _ = Task.Delay(5000).ContinueWith(_ => InvokeAsync(() =>
            {
                ClearStatusMessage();
                StateHasChanged();
            }));
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetActivityIcon(ActivityType activity) => activity switch
    {
        ActivityType.Course => "fa-graduation-cap",
        ActivityType.Meeting => "fa-handshake",
        ActivityType.Training => "fa-dumbbell",
        _ => "fa-tasks"
    };
}