@page "/rooms"
@rendermode InteractiveServer
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject IBookingService BookingService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Rooms Management</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="container-fluid">
            <!-- Header Section -->
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h2">
                            <i class="fas fa-door-open me-2"></i>Rooms Management
                        </h1>
                        <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="headerAdminContext">
                            <Authorized>
                                <div class="btn-group">
                                    <button class="btn btn-primary btn-lg" @onclick="ShowAddRoomModal" type="button">
                                        <i class="fas fa-plus me-2"></i> Add New Room
                                    </button>
                                </div>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Total Rooms</h6>
                                    <h3 class="mb-0">@(rooms?.Count() ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-door-open fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Total Capacity</h6>
                                    <h3 class="mb-0">@(rooms?.Sum(r => r.Capacity) ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-users fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Available Buildings</h6>
                                    <h3 class="mb-0">@(buildings?.Count() ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-building fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Messages -->
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="row mb-3">
                    <div class="col-12">
                        <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                            <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                            @statusMessage
                            <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                        </div>
                    </div>
                </div>
            }

            <!-- User Profile Integration Notice (from User-profile-history branch) -->
            <AuthorizeView Roles="Renter" Policy="ActiveUser" Context="renterNoticeContext">
                <Authorized>
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="alert alert-info" role="alert">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <div>
                                        <strong>Room Booking Information</strong>
                                        <p class="mb-0">
                                            Browse available rooms below. For booking history and profile management, 
                                            visit your <a href="/profile" class="alert-link">Profile</a> and 
                                            <a href="/history" class="alert-link">History</a> pages.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            <!-- Rooms Grid -->
            <div class="row">
                @if (rooms == null)
                {
                    <div class="col-12 text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (!rooms.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            <div class="mb-3">
                                <i class="fas fa-door-open fa-4x text-muted"></i>
                            </div>
                            <h4>No Rooms Available</h4>
                            <p>
                                @* Show different messages based on user role *@
                                <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="noRoomsAdminContext">
                                    <Authorized>Start by adding your first room to the system!</Authorized>
                                    <NotAuthorized>No rooms are currently available for booking. Please contact an administrator.</NotAuthorized>
                                </AuthorizeView>
                            </p>
                            <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="addFirstRoomContext">
                                <Authorized>
                                    <button class="btn btn-primary btn-lg" @onclick="ShowAddRoomModal" type="button">
                                        <i class="fas fa-plus me-2"></i> Add Your First Room
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var room in rooms)
                    {
                        <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                            <div class="card h-100 room-card">
                                <div class="card-header d-flex justify-content-between align-items-center bg-light">
                                    <h5 class="card-title mb-0 text-primary">
                                        @room.Name
                                    </h5>
                                    <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="roomCardAdminContext">
                                        <Authorized>
                                            <div class="dropdown">
                                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><button class="dropdown-item" @onclick="() => EditRoom(room)" type="button">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button></li>
                                                    <li><button class="dropdown-item text-danger" @onclick="() => DeleteRoom(room)" type="button">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button></li>
                                                </ul>
                                            </div>
                                        </Authorized>
                                    </AuthorizeView>
                                </div>
                                <div class="card-body">
                                    <div class="room-info">
                                        <p class="mb-2">
                                            <i class="fas fa-building text-primary me-2"></i>
                                            <strong>Building:</strong> @room.Building?.Name
                                        </p>
                                        @if (!string.IsNullOrEmpty(room.RoomNumber))
                                        {
                                            <p class="mb-2">
                                                <i class="fas fa-door-open text-success me-2"></i>
                                                <strong>Room Number:</strong> @room.RoomNumber
                                            </p>
                                        }
                                        <p class="mb-2">
                                            <i class="fas fa-users text-info me-2"></i>
                                            <strong>Capacity:</strong> @room.Capacity people
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas @GetActivityIcon(room.Activity) @GetActivityColor(room.Activity) me-2"></i>
                                            <strong>Activity:</strong> @room.Activity
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-calendar text-warning me-2"></i>
                                            <strong>Date:</strong> @room.Date.ToString("MMM dd, yyyy")
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-clock text-info me-2"></i>
                                            <strong>Time:</strong> @room.Time.ToString(@"hh\:mm")
                                        </p>
                                        @if (!string.IsNullOrEmpty(room.Description))
                                        {
                                            <p class="text-muted small">
                                                <i class="fas fa-info-circle me-1"></i>
                                                @room.Description
                                            </p>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <div class="d-grid gap-2">
                                        <AuthorizeView Roles="Renter,Administrator,Secretary" Policy="ActiveUser" Context="bookButtonContext">
                                            <Authorized>
                                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowBookingModal(room)" type="button">
                                                    <i class="fas fa-calendar-plus me-1"></i> Book Room
                                                </button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Features Overview (from User-profile-history branch) -->
            @if (rooms == null || !rooms.Any())
            {
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-star"></i> Room Management Features</h5>
                            </div>
                            <div class="card-body">
                                <p class="card-text">This platform provides comprehensive room management capabilities:</p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <ul class="list-unstyled">
                                            <li><i class="fas fa-check text-success me-2"></i> Browse available rooms</li>
                                            <li><i class="fas fa-check text-success me-2"></i> View room details and amenities</li>
                                            <li><i class="fas fa-check text-success me-2"></i> Check room availability</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <ul class="list-unstyled">
                                            <li><i class="fas fa-check text-success me-2"></i> Make room reservations</li>
                                            <li><i class="fas fa-check text-success me-2"></i> Manage existing bookings</li>
                                            <li><i class="fas fa-check text-success me-2"></i> Track booking history</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Add/Edit Room Modal (Admin/Secretary only) -->
        <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="modalAdminContext">
            <Authorized>
                @if (showRoomModal)
                {
                    <!-- Modal Backdrop -->
                    <div class="modal-backdrop fade show" @onclick="CloseModal"></div>
                    
                    <!-- Modal Dialog -->
                    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content" @onclick:stopPropagation="true">
                                <div class="modal-header bg-primary text-white">
                                    <h5 class="modal-title">
                                        <i class="fas @(isEditMode ? "fa-edit" : "fa-plus") me-2"></i>
                                        @(isEditMode ? "Edit Room" : "Add New Room")
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal" aria-label="Close"></button>
                                </div>
                                
                                <EditForm Model="roomModel" OnValidSubmit="SaveRoom" Context="editContext">
                                    <DataAnnotationsValidator />
                                    <div class="modal-body">
                                        <ValidationSummary class="text-danger mb-3" />
                                        
                                        <!-- Room Name -->
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-tag me-1"></i>Room Name <span class="text-danger">*</span>
                                            </label>
                                            <InputText class="form-control form-control-lg" @bind-Value="roomModel.Name" 
                                                       placeholder="Enter room name (e.g., Conference Room A, Lab 101)" />
                                            <ValidationMessage For="() => roomModel.Name" class="text-danger" />
                                        </div>

                                        <!-- Building Input -->
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-building me-1"></i>Building <span class="text-danger">*</span>
                                            </label>
                                            <div class="input-group">
                                                <InputText class="form-control form-control-lg" @bind-Value="buildingName" 
                                                           placeholder="Enter building name" list="buildingsList" />
                                                <datalist id="buildingsList">
                                                    @if (buildings != null)
                                                    {
                                                        @foreach (var building in buildings)
                                                        {
                                                            <option value="@building.Name"></option>
                                                        }
                                                    }
                                                </datalist>
                                            </div>
                                            <div class="form-text">Start typing to see suggestions or enter a new building name</div>
                                        </div>

                                        <!-- Activity Selection -->
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-tasks me-1"></i>Activity Type <span class="text-danger">*</span>
                                            </label>
                                            <InputSelect class="form-select form-select-lg" @bind-Value="roomModel.Activity">
                                                <option value="@ActivityType.Course">Course</option>
                                                <option value="@ActivityType.Meeting">Meeting</option>
                                                <option value="@ActivityType.Training">Training</option>
                                            </InputSelect>
                                            <ValidationMessage For="() => roomModel.Activity" class="text-danger" />
                                            <div class="form-text">Select the primary activity type for this room</div>
                                        </div>

                                        <!-- Date and Time Section -->
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">
                                                        <i class="fas fa-calendar me-1"></i>Date <span class="text-danger">*</span>
                                                    </label>
                                                    <InputDate class="form-control" @bind-Value="roomModel.Date" />
                                                    <ValidationMessage For="() => roomModel.Date" class="text-danger" />
                                                    <div class="form-text">Select the date for room availability</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">
                                                        <i class="fas fa-clock me-1"></i>Time <span class="text-danger">*</span>
                                                    </label>
                                                    <InputText class="form-control" @bind-Value="timeInput" 
                                                               type="time" placeholder="09:00" />
                                                    <ValidationMessage For="() => roomModel.Time" class="text-danger" />
                                                    <div class="form-text">Select the time for room availability</div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Room Number and Capacity -->
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">
                                                        <i class="fas fa-door-open me-1"></i>Room Number
                                                    </label>
                                                    <InputText class="form-control" @bind-Value="roomModel.RoomNumber" 
                                                               placeholder="e.g., A101, B-205" />
                                                    <div class="form-text">Optional room identifier</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">
                                                        <i class="fas fa-users me-1"></i>Capacity <span class="text-danger">*</span>
                                                    </label>
                                                    <InputNumber class="form-control" @bind-Value="roomModel.Capacity" 
                                                                 min="1" placeholder="Enter maximum capacity" />
                                                    <ValidationMessage For="() => roomModel.Capacity" class="text-danger" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Description -->
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-align-left me-1"></i>Description
                                            </label>
                                            <InputTextArea class="form-control" rows="3" @bind-Value="roomModel.Description" 
                                                           placeholder="Room description, equipment, special features..." />
                                            <div class="form-text">Optional additional information</div>
                                        </div>
                                    </div>
                                    
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                                            <i class="fas fa-times me-1"></i> Cancel
                                        </button>
                                        <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                            @if (isProcessing)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                            }
                                            <i class="fas @(isEditMode ? "fa-save" : "fa-plus") me-1"></i>
                                            @(isEditMode ? "Update Room" : "Add Room")
                                        </button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Booking Modal -->
        @if (showBookingModal)
        {
            <!-- Modal Backdrop -->
            <div class="modal-backdrop fade show" @onclick="CloseBookingModal"></div>
            
            <!-- Modal Dialog -->
            <div class="modal fade show d-block booking-modal" tabindex="-1" style="z-index: 1060;">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">
                                <i class="fas fa-calendar-plus me-2"></i>
                                Book Room: @selectedRoom?.Name
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseBookingModal" aria-label="Close"></button>
                        </div>
                        
                        <EditForm Model="bookingModel" OnValidSubmit="CreateBooking" Context="bookingContext">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <ValidationSummary class="text-danger mb-3" />
                                
                                <!-- Room Information -->
                                <div class="alert alert-info mb-3">
                                    <h6><i class="fas fa-info-circle me-2"></i>Room Details</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p class="mb-1"><strong>Room:</strong> @selectedRoom?.Name</p>
                                            <p class="mb-1"><strong>Building:</strong> @selectedRoom?.Building?.Name</p>
                                            <p class="mb-0"><strong>Capacity:</strong> @selectedRoom?.Capacity people</p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="mb-1"><strong>Activity:</strong> @selectedRoom?.Activity</p>
                                            @if (!string.IsNullOrEmpty(selectedRoom?.RoomNumber))
                                            {
                                                <p class="mb-0"><strong>Room Number:</strong> @selectedRoom.RoomNumber</p>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Booking Title -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-tag me-1"></i>Booking Title <span class="text-danger">*</span>
                                    </label>
                                    <InputText class="form-control" @bind-Value="bookingModel.Title" 
                                               placeholder="Enter a title for your booking" />
                                    <ValidationMessage For="() => bookingModel.Title" class="text-danger" />
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-align-left me-1"></i>Description
                                    </label>
                                    <InputTextArea class="form-control" rows="3" @bind-Value="bookingModel.Description" 
                                                   placeholder="Describe the purpose or agenda of your booking" />
                                </div>

                                <!-- Date and Time -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-calendar me-1"></i>Start Date <span class="text-danger">*</span>
                                            </label>
                                            <InputDate class="form-control" @bind-Value="startDate" />
                                            <ValidationMessage For="() => bookingModel.StartDate" class="text-danger" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-clock me-1"></i>Start Time <span class="text-danger">*</span>
                                            </label>
                                            <InputText class="form-control" @bind-Value="startTime" type="time" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-calendar me-1"></i>End Date <span class="text-danger">*</span>
                                            </label>
                                            <InputDate class="form-control" @bind-Value="endDate" />
                                            <ValidationMessage For="() => bookingModel.EndDate" class="text-danger" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-clock me-1"></i>End Time <span class="text-danger">*</span>
                                            </label>
                                            <InputText class="form-control" @bind-Value="endTime" type="time" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Attendee Count -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-users me-1"></i>Expected Attendees
                                    </label>
                                    <InputNumber class="form-control" @bind-Value="bookingModel.AttendeeCount" 
                                                 min="1" max="@selectedRoom?.Capacity" placeholder="Number of people attending" />
                                    @if (selectedRoom != null)
                                    {
                                        <div class="form-text">Maximum capacity: @selectedRoom.Capacity people</div>
                                    }
                                </div>

                                <!-- Special Requirements -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-clipboard-list me-1"></i>Special Requirements
                                    </label>
                                    <InputTextArea class="form-control" rows="2" @bind-Value="bookingModel.SpecialRequirements" 
                                                   placeholder="Any special equipment, setup, or requirements..." />
                                </div>
                            </div>
                            
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseBookingModal">
                                    <i class="fas fa-times me-1"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-success" disabled="@isProcessing">
                                    @if (isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="fas fa-check me-1"></i>
                                    Create Booking
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="text-center mt-5">
                        <i class="fas fa-lock fa-4x text-muted mb-4"></i>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need to be logged in to access the rooms management system.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Room>? rooms;
    private IEnumerable<Building>? buildings;
    private bool showRoomModal = false;
    private bool showBookingModal = false;
    private bool isEditMode = false;
    private bool isProcessing = false;
    private Room roomModel = new Room();
    private Booking bookingModel = new Booking();
    private Room? selectedRoom;
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private string buildingName = string.Empty;
    private string timeInput = "09:00";
    
    // Booking form fields
    private DateTime startDate = DateTime.Today.AddDays(1);
    private DateTime endDate = DateTime.Today.AddDays(1);
    private string startTime = "09:00";
    private string endTime = "10:00";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            buildings = await BuildingService.GetAllBuildingsAsync();
            rooms = await RoomService.GetAllRoomsAsync();
            
            // Force a state refresh to ensure UI is updated with fresh data
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading data: {ex.Message}", "error");
        }
    }

    private void ShowAddRoomModal()
    {
        // Create a completely fresh room model
        roomModel = new Room { 
            Id = 0, // Ensure this is 0 for new rooms
            Capacity = 1, 
            Activity = ActivityType.Course,
            Date = DateTime.Today,
            Time = TimeSpan.FromHours(9),
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };
        buildingName = string.Empty;
        timeInput = "09:00";
        isEditMode = false;
        showRoomModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void EditRoom(Room room)
    {
        // Don't create a new Room object, just copy the properties we need
        roomModel = new Room();
        roomModel.Id = room.Id;
        roomModel.Name = room.Name;
        roomModel.RoomNumber = room.RoomNumber;
        roomModel.Capacity = room.Capacity;
        roomModel.Description = room.Description;
        roomModel.BuildingId = room.BuildingId;
        roomModel.Activity = room.Activity;
        roomModel.Date = room.Date;
        roomModel.Time = room.Time;
        roomModel.IsActive = room.IsActive;
        roomModel.CreatedAt = room.CreatedAt;
        
        buildingName = room.Building?.Name ?? string.Empty;
        timeInput = room.Time.ToString(@"hh\:mm");
        isEditMode = true;
        showRoomModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void CloseModal()
    {
        showRoomModal = false;
        roomModel = new Room(); // Create a fresh instance
        buildingName = string.Empty;
        timeInput = "09:00";
        isProcessing = false;
        isEditMode = false;
        StateHasChanged();
    }

    private async Task ShowBookingModal(Room room)
    {
        try
        {
            selectedRoom = room;
            
            // Get current user ID immediately when showing the modal
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                ShowStatusMessage("User not authenticated. Please log in again.", "error");
                return;
            }

            bookingModel = new Booking
            {
                UserId = userId,  // Set user ID immediately
                RoomId = room.Id,
                Title = "",
                Description = "",
                AttendeeCount = 1,
                SpecialRequirements = "",
                Status = BookingStatus.Pending
            };
            
            // Set default dates to tomorrow
            startDate = DateTime.Today.AddDays(1);
            endDate = DateTime.Today.AddDays(1);
            startTime = "09:00";
            endTime = "10:00";
            
            showBookingModal = true;
            ClearStatusMessage();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error opening booking modal: {ex.Message}", "error");
        }
    }

    private void CloseBookingModal()
    {
        showBookingModal = false;
        selectedRoom = null;
        bookingModel = new Booking();
        isProcessing = false;
        StateHasChanged();
    }

    private async Task CreateBooking()
    {
        if (selectedRoom == null)
        {
            ShowStatusMessage("Room not selected.", "error");
            return;
        }

        // Validate required fields
        if (string.IsNullOrWhiteSpace(bookingModel.Title))
        {
            ShowStatusMessage("Booking title is required.", "error");
            return;
        }

        // Validate user is still authenticated
        if (string.IsNullOrEmpty(bookingModel.UserId))
        {
            ShowStatusMessage("User authentication expired. Please refresh the page and try again.", "error");
            return;
        }

        // Parse and validate times
        if (!TimeSpan.TryParse(startTime, out var startTimeSpan) || !TimeSpan.TryParse(endTime, out var endTimeSpan))
        {
            ShowStatusMessage("Invalid time format.", "error");
            return;
        }

        // Combine dates and times
        var startDateTime = startDate.Date.Add(startTimeSpan);
        var endDateTime = endDate.Date.Add(endTimeSpan);

        // Validate booking times
        if (startDateTime >= endDateTime)
        {
            ShowStatusMessage("End time must be after start time.", "error");
            return;
        }

        if (startDateTime <= DateTime.Now)
        {
            ShowStatusMessage("Booking must be scheduled for the future.", "error");
            return;
        }

        // Validate attendee count
        if (bookingModel.AttendeeCount.HasValue && bookingModel.AttendeeCount > selectedRoom.Capacity)
        {
            ShowStatusMessage($"Attendee count cannot exceed room capacity of {selectedRoom.Capacity}.", "error");
            return;
        }

        isProcessing = true;
        StateHasChanged();

        try
        {
            // Set final booking properties
            bookingModel.RoomId = selectedRoom.Id;
            bookingModel.StartDate = startDateTime;
            bookingModel.EndDate = endDateTime;
            bookingModel.Status = BookingStatus.Pending;

            // Create the booking
            var createdBooking = await BookingService.CreateBookingAsync(bookingModel);
            
            ShowStatusMessage($"Booking '{createdBooking.Title}' created successfully! You can view it in your bookings page.", "success");
            CloseBookingModal();
        }
        catch (InvalidOperationException ex)
        {
            ShowStatusMessage($"Booking failed: {ex.Message}", "error");
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error creating booking: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SaveRoom()
    {
        // Basic validation
        if (string.IsNullOrWhiteSpace(roomModel.Name))
        {
            ShowStatusMessage("Room name is required.", "error");
            return;
        }

        if (string.IsNullOrWhiteSpace(buildingName))
        {
            ShowStatusMessage("Building name is required.", "error");
            return;
        }

        if (roomModel.Capacity <= 0)
        {
            ShowStatusMessage("Capacity must be greater than 0.", "error");
            return;
        }

        if (roomModel.Date == DateTime.MinValue)
        {
            ShowStatusMessage("Date is required.", "error");
            return;
        }

        if (!TimeSpan.TryParse(timeInput, out var time))
        {
            ShowStatusMessage("Invalid time format. Please use HH:mm.", "error");
            return;
        }
        roomModel.Time = time;

        isProcessing = true;
        StateHasChanged();

        try
        {
            // Find or create building
            var existingBuilding = buildings?.FirstOrDefault(b => b.Name.Equals(buildingName, StringComparison.OrdinalIgnoreCase));
            if (existingBuilding != null)
            {
                roomModel.BuildingId = existingBuilding.Id;
            }
            else
            {
                // Create new building
                var newBuilding = new Building 
                { 
                    Name = buildingName, 
                    Address = string.Empty,
                    Description = $"Auto-created building for {buildingName}",
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                };
                var createdBuilding = await BuildingService.CreateBuildingAsync(newBuilding);
                roomModel.BuildingId = createdBuilding.Id;
                
                // Reload buildings to include the new one
                buildings = await BuildingService.GetAllBuildingsAsync();
            }

            // Ensure BuildingId is set properly
            if (roomModel.BuildingId <= 0)
            {
                ShowStatusMessage("Unable to determine building ID. Please try again.", "error");
                return;
            }

            if (isEditMode)
            {
                // Ensure we're working with a valid room ID
                if (roomModel.Id <= 0)
                {
                    ShowStatusMessage("Invalid room ID for update operation.", "error");
                    return;
                }
                
                await RoomService.UpdateRoomAsync(roomModel);
                ShowStatusMessage($"Room '{roomModel.Name}' updated successfully!", "success");
            }
            else
            {
                // For new rooms, ensure ID is 0
                roomModel.Id = 0;
                await RoomService.CreateRoomAsync(roomModel);
                ShowStatusMessage($"Room '{roomModel.Name}' created successfully!", "success");
            }
            
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error saving room: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteRoom(Room room)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete '{room.Name}'? This action cannot be undone."))
        {
            try
            {
                var result = await RoomService.DeleteRoomAsync(room.Id);
                if (result)
                {
                    ShowStatusMessage($"Room '{room.Name}' permanently deleted successfully!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to delete room. Room not found.", "error");
                }
            }
            catch (InvalidOperationException ex)
            {
                ShowStatusMessage($"Cannot delete room: {ex.Message}", "error");
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error deleting room: {ex.Message}", "error");
            }
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        // Auto-hide success messages after 5 seconds
        if (type == "success")
        {
            _ = Task.Delay(5000).ContinueWith(_ => 
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetActivityIcon(ActivityType activity)
    {
        return activity switch
        {
            ActivityType.Course => "fa-graduation-cap",
            ActivityType.Meeting => "fa-handshake",
            ActivityType.Training => "fa-dumbbell",
            _ => "fa-tasks"
        };
    }

    private string GetActivityColor(ActivityType activity)
    {
        return activity switch
        {
            ActivityType.Course => "text-success",
            ActivityType.Meeting => "text-primary",
            ActivityType.Training => "text-warning",
            _ => "text-secondary"
        };
    }
