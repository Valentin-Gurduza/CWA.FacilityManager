@page "/bookings"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using CWA.FacilityManager.Application.Interfaces
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject IBookingService BookingService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>My Bookings</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2">
                    <i class="fas fa-calendar-check me-2"></i>My Bookings
                </h1>
                <a href="/rooms" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Book New Room
                </a>
            </div>
        </div>
    </div>

    <!-- Status Messages -->
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                    <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                    @statusMessage
                    <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                </div>
            </div>
        </div>
    }

    <!-- Bookings Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@(bookings?.Count() ?? 0)</h3>
                    <p class="mb-0">Total Bookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@(bookings?.Count(b => b.Status == BookingStatus.Pending) ?? 0)</h3>
                    <p class="mb-0">Pending</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@(bookings?.Count(b => b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.InProgress) ?? 0)</h3>
                    <p class="mb-0">Active</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-secondary text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@(bookings?.Count(b => b.Status == BookingStatus.Completed) ?? 0)</h3>
                    <p class="mb-0">Completed</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bookings List -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-list me-2"></i>Your Booking History
                    </h5>
                </div>
                <div class="card-body">
                    @if (bookings == null)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading your bookings...</p>
                        </div>
                    }
                    else if (!bookings.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                            <h4>No Bookings Found</h4>
                            <p class="text-muted">You haven't made any room bookings yet.</p>
                            <a href="/rooms" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Book Your First Room
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Title</th>
                                        <th>Room</th>
                                        <th>Date & Time</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in bookings.OrderByDescending(b => b.StartDate))
                                    {
                                        <tr class="@GetRowClass(booking)">
                                            <td>
                                                <div>
                                                    <strong>@booking.Title</strong>
                                                    @if (!string.IsNullOrEmpty(booking.Description))
                                                    {
                                                        <br />
                                                        <small class="text-muted">@booking.Description</small>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@booking.Room?.Name</strong>
                                                    <br />
                                                    <small class="text-muted">
                                                        @booking.Room?.Building?.Name
                                                        @if (!string.IsNullOrEmpty(booking.Room?.RoomNumber))
                                                        {
                                                            <span> - @booking.Room.RoomNumber</span>
                                                        }
                                                    </small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@booking.StartDate.ToString("MMM dd, yyyy")</strong>
                                                    <br />
                                                    <small class="text-muted">
                                                        @booking.StartDate.ToString("HH:mm") - @booking.EndDate.ToString("HH:mm")
                                                        @if (booking.StartDate.Date != booking.EndDate.Date)
                                                        {
                                                            <span> (Multi-day)</span>
                                                        }
                                                    </small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(booking.Status)">
                                                    @booking.Status
                                                </span>
                                                @if (booking.AttendeeCount.HasValue)
                                                {
                                                    <br />
                                                    <small class="text-muted">
                                                        <i class="fas fa-users me-1"></i>@booking.AttendeeCount people
                                                    </small>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group-vertical btn-group-sm" role="group">
                                                    <button class="btn btn-outline-info btn-sm" @onclick="() => ViewBookingDetails(booking)" type="button">
                                                        <i class="fas fa-eye"></i> View
                                                    </button>
                                                    @if (booking.Status == BookingStatus.Pending && booking.StartDate > DateTime.Now)
                                                    {
                                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => CancelBooking(booking)" type="button">
                                                            <i class="fas fa-times"></i> Cancel
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Help Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-question-circle me-2"></i>Booking Status Guide
                    </h5>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><span class="badge bg-warning text-dark">Pending</span> - Waiting for approval</li>
                                <li><span class="badge bg-success">Confirmed</span> - Approved and scheduled</li>
                                <li><span class="badge bg-primary">In Progress</span> - Currently active</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><span class="badge bg-secondary">Completed</span> - Finished successfully</li>
                                <li><span class="badge bg-danger">Cancelled</span> - Booking was cancelled</li>
                            </ul>
                        </div>
                    </div>
                    <p class="mb-0 text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        You can only cancel pending bookings. For other changes, please contact an administrator.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Booking Details Modal -->
@if (showDetailsModal && selectedBooking != null)
{
    <!-- Modal Backdrop -->
    <div class="modal-backdrop fade show" @onclick="CloseDetailsModal"></div>
    
    <!-- Modal Dialog -->
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">
                        <i class="fas fa-calendar-check me-2"></i>
                        Booking Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetailsModal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6><i class="fas fa-info-circle me-2"></i>Booking Information</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Title:</strong></td>
                                    <td>@selectedBooking.Title</td>
                                </tr>
                                <tr>
                                    <td><strong>Status:</strong></td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(selectedBooking.Status)">
                                            @selectedBooking.Status
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Created:</strong></td>
                                    <td>@selectedBooking.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                </tr>
                                @if (selectedBooking.AttendeeCount.HasValue)
                                {
                                    <tr>
                                        <td><strong>Attendees:</strong></td>
                                        <td>@selectedBooking.AttendeeCount people</td>
                                    </tr>
                                }
                                @if (selectedBooking.TotalCost.HasValue)
                                {
                                    <tr>
                                        <td><strong>Cost:</strong></td>
                                        <td>$@selectedBooking.TotalCost.Value.ToString("F2")</td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6><i class="fas fa-door-open me-2"></i>Room Information</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Room:</strong></td>
                                    <td>@selectedBooking.Room?.Name</td>
                                </tr>
                                <tr>
                                    <td><strong>Building:</strong></td>
                                    <td>@selectedBooking.Room?.Building?.Name</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(selectedBooking.Room?.RoomNumber))
                                {
                                    <tr>
                                        <td><strong>Room Number:</strong></td>
                                        <td>@selectedBooking.Room.RoomNumber</td>
                                    </tr>
                                }
                                <tr>
                                    <td><strong>Capacity:</strong></td>
                                    <td>@selectedBooking.Room?.Capacity people</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    
                    <div class="row mt-3">
                        <div class="col-12">
                            <h6><i class="fas fa-calendar me-2"></i>Schedule</h6>
                            <div class="alert alert-light">
                                <div class="row">
                                    <div class="col-md-6">
                                        <strong>Start:</strong> @selectedBooking.StartDate.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                    <div class="col-md-6">
                                        <strong>End:</strong> @selectedBooking.EndDate.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <strong>Duration:</strong> @selectedBooking.Duration.TotalHours.ToString("F1") hours
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedBooking.Description))
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6><i class="fas fa-align-left me-2"></i>Description</h6>
                                <p>@selectedBooking.Description</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedBooking.SpecialRequirements))
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6><i class="fas fa-clipboard-list me-2"></i>Special Requirements</h6>
                                <p>@selectedBooking.SpecialRequirements</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedBooking.CancellationReason))
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="alert alert-warning">
                                    <h6><i class="fas fa-exclamation-triangle me-2"></i>Cancellation Reason</h6>
                                    <p class="mb-0">@selectedBooking.CancellationReason</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">
                        <i class="fas fa-times me-1"></i> Close
                    </button>
                    @if (selectedBooking.Status == BookingStatus.Pending && selectedBooking.StartDate > DateTime.Now)
                    {
                        <button type="button" class="btn btn-danger" @onclick="() => CancelBooking(selectedBooking)">
                            <i class="fas fa-times me-1"></i> Cancel Booking
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<Booking>? bookings;
    private Booking? selectedBooking;
    private bool showDetailsModal = false;
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                bookings = await BookingService.GetBookingsByUserAsync(userId);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading bookings: {ex.Message}", "error");
        }
    }

    private void ViewBookingDetails(Booking booking)
    {
        selectedBooking = booking;
        showDetailsModal = true;
        StateHasChanged();
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedBooking = null;
        StateHasChanged();
    }

    private async Task CancelBooking(Booking booking)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to cancel the booking '{booking.Title}'? This action cannot be undone."))
        {
            try
            {
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    var result = await BookingService.CancelBookingAsync(booking.Id, "Cancelled by user", userId);
                    if (result)
                    {
                        ShowStatusMessage($"Booking '{booking.Title}' has been cancelled successfully.", "success");
                        await LoadBookings(); // Refresh the bookings list
                        CloseDetailsModal(); // Close modal if open
                    }
                    else
                    {
                        ShowStatusMessage("Failed to cancel booking. Please try again.", "error");
                    }
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error cancelling booking: {ex.Message}", "error");
            }
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        // Auto-hide success messages after 5 seconds
        if (type == "success")
        {
            _ = Task.Delay(5000).ContinueWith(_ => 
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetStatusBadgeClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bg-warning text-dark",
            BookingStatus.Confirmed => "bg-success",
            BookingStatus.InProgress => "bg-primary",
            BookingStatus.Completed => "bg-secondary",
            BookingStatus.Cancelled => "bg-danger",
            _ => "bg-light text-dark"
        };
    }

    private string GetRowClass(Booking booking)
    {
        if (booking.Status == BookingStatus.Cancelled)
            return "table-danger";
        if (booking.IsPastEvent && booking.Status != BookingStatus.Completed)
            return "table-warning";
        return "";
    }
}