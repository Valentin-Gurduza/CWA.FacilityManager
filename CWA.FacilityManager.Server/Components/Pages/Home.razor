@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Home - CWA Facility Manager</PageTitle>

<div class="hero-section">
    <div class="hero-content fade-in">
        <div class="hero-text">
            <h1 class="hero-title text-gradient">
                <span class="bi bi-building-fill me-3"></span>
                CWA Facility Manager
            </h1>
            <p class="hero-subtitle">
                Modern facility management platform designed for efficiency, security, and seamless user experience.
            </p>
            <AuthorizeView>
                <Authorized>
                    <div class="welcome-message glass-effect mt-4 p-3">
                        <span class="bi bi-person-check-fill me-2"></span>
                        Welcome back, <strong>@context.User.Identity?.Name</strong>!
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="hero-actions mt-4">
                        <a href="/Account/Login" class="btn btn-primary btn-lg me-3 hover-lift">
                            <span class="bi bi-box-arrow-in-right me-2"></span>
                            Sign In
                        </a>
                        <a href="/Account/Register" class="btn btn-outline-primary btn-lg hover-lift">
                            <span class="bi bi-person-plus me-2"></span>
                            Register
                        </a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
        <div class="hero-visual">
            <div class="floating-card glass-effect">
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-icon">
                            <span class="bi bi-building-fill"></span>
                        </div>
                        <div class="stat-info">
                            <h3>5</h3>
                            <p>Facilities</p>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon">
                            <span class="bi bi-door-open-fill"></span>
                        </div>
                        <div class="stat-info">
                            <h3>25</h3>
                            <p>Rooms</p>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon">
                            <span class="bi bi-calendar-check-fill"></span>
                        </div>
                        <div class="stat-info">
                            <h3>150</h3>
                            <p>Bookings</p>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon">
                            <span class="bi bi-people-fill"></span>
                        </div>
                        <div class="stat-info">
                            <h3>320</h3>
                            <p>Users</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<AuthorizeView>
    <Authorized>
        <!-- Email Confirmation Check -->
        <AuthorizeView Policy="EmailConfirmed" Context="emailContext">
            <NotAuthorized>
                <div class="container mb-4">
                    <div class="alert alert-warning">
                        <div class="d-flex align-items-center">
                            <span class="bi bi-exclamation-triangle-fill me-3 fs-4"></span>
                            <div>
                                <h5 class="mb-1">Email Confirmation Required</h5>
                                <p class="mb-0">
                                    Some features are restricted until you 
                                    <a href="Account/Manage/Email" class="alert-link">confirm your email address</a>.
                                    <a href="Account/ResendEmailConfirmation" class="alert-link ms-2">Request a new confirmation link</a>.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <div class="quick-actions-section">
            <div class="container">
                <div class="section-header text-center mb-5">
                    <h2 class="section-title">
                        <span class="bi bi-lightning-charge-fill me-2"></span>
                        Quick Actions
                    </h2>
                    <p class="section-subtitle">
                        Get started with these frequently used features
                    </p>
                </div>
                
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6">
                        <a href="/profile" class="quick-action-card glass-effect hover-lift">
                            <div class="action-icon">
                                <span class="bi bi-person-circle"></span>
                            </div>
                            <h4>My Profile</h4>
                            <p>View and update your information</p>
                        </a>
                    </div>
                    
                    <div class="col-lg-3 col-md-6">
                        <a href="/rooms" class="quick-action-card glass-effect hover-lift">
                            <div class="action-icon">
                                <span class="bi bi-door-open-fill"></span>
                            </div>
                            <h4>Browse Rooms</h4>
                            <p>Find and reserve meeting spaces</p>
                        </a>
                    </div>
                    
                    <div class="col-lg-3 col-md-6">
                        <a href="/bookings" class="quick-action-card glass-effect hover-lift">
                            <div class="action-icon">
                                <span class="bi bi-calendar-check-fill"></span>
                            </div>
                            <h4>My Bookings</h4>
                            <p>Manage your reservations</p>
                        </a>
                    </div>
                    
                    <div class="col-lg-3 col-md-6">
                        <a href="/calendar" class="quick-action-card glass-effect hover-lift">
                            <div class="action-icon">
                                <span class="bi bi-calendar-week-fill"></span>
                            </div>
                            <h4>Task Calendar</h4>
                            <p>View your schedule and tasks</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role-based Administration Section -->
        <AuthorizeView Roles="Administrator,Secretary" Policy="ActiveAdminOrSecretary" Context="adminContext">
            <Authorized>
                <div class="admin-section">
                    <div class="container">
                        <div class="section-header text-center mb-5">
                            <h2 class="section-title">
                                <span class="bi bi-gear-fill me-2"></span>
                                Administration
                            </h2>
                            <p class="section-subtitle">
                                Manage platform settings and administrative tasks
                            </p>
                        </div>
                        
                        <div class="row g-4">
                            <div class="col-lg-4 col-md-6">
                                <a href="/admin/users" class="admin-action-card glass-effect hover-lift">
                                    <div class="action-icon admin-icon">
                                        <span class="bi bi-people-fill"></span>
                                    </div>
                                    <h4>User Management</h4>
                                    <p>Manage user accounts and profiles</p>
                                </a>
                            </div>
                            
                            <div class="col-lg-4 col-md-6">
                                <a href="/admin/facilities" class="admin-action-card glass-effect hover-lift">
                                    <div class="action-icon admin-icon">
                                        <span class="bi bi-building-fill"></span>
                                    </div>
                                    <h4>Facility Management</h4>
                                    <p>Configure facilities and rooms</p>
                                </a>
                            </div>
                            
                            <AuthorizeView Roles="Administrator" Policy="ActiveAdmin" Context="roleContext">
                                <Authorized>
                                    <div class="col-lg-4 col-md-6">
                                        <a href="/admin/roles" class="admin-action-card glass-effect hover-lift">
                                            <div class="action-icon admin-icon">
                                                <span class="bi bi-shield-check"></span>
                                            </div>
                                            <h4>Role Management</h4>
                                            <p>Configure user roles and permissions</p>
                                        </a>
                                    </div>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="features-section">
            <div class="container">
                <div class="section-header text-center mb-5">
                    <h2 class="section-title">
                        <span class="bi bi-star-fill me-2"></span>
                        Platform Features
                    </h2>
                    <p class="section-subtitle">
                        Comprehensive facility management tools for modern organizations
                    </p>
                </div>
                
                <div class="row g-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-card hover-lift slide-in">
                            <div class="feature-icon">
                                <span class="bi bi-person-circle"></span>
                            </div>
                            <h3 class="feature-title">Enhanced Profiles</h3>
                            <p class="feature-description">
                                Complete profile management with role-based access and department tracking.
                            </p>
                            <ul class="feature-list">
                                <li><span class="bi bi-check-circle-fill me-2"></span>Personal information</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Department tracking</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Role-based access</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-card hover-lift slide-in">
                            <div class="feature-icon">
                                <span class="bi bi-calendar-week-fill"></span>
                            </div>
                            <h3 class="feature-title">Smart Scheduling</h3>
                            <p class="feature-description">
                                Intelligent booking system with conflict detection and calendar integration.
                            </p>
                            <ul class="feature-list">
                                <li><span class="bi bi-check-circle-fill me-2"></span>Real-time availability</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Conflict prevention</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Calendar sync</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-card hover-lift slide-in">
                            <div class="feature-icon">
                                <span class="bi bi-shield-check-fill"></span>
                            </div>
                            <h3 class="feature-title">Security & Access</h3>
                            <p class="feature-description">
                                Three-tier role system with comprehensive audit trails and secure authentication.
                            </p>
                            <ul class="feature-list">
                                <li><span class="bi bi-check-circle-fill me-2"></span>Role management</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Activity tracking</li>
                                <li><span class="bi bi-check-circle-fill me-2"></span>Secure access</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>