@page "/admin/bookings"
@using Microsoft.AspNetCore.Authorization
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode InteractiveServer
@inject IBookingService BookingService
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Booking Management</PageTitle>

<AuthorizeView Policy="ActiveAdminOrSecretary">
    <Authorized>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h3">
                            <i class="fas fa-calendar-check me-2 text-primary"></i>Booking Management
                        </h1>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary" @onclick="ToggleCalendarView" disabled="@isProcessing">
                                <i class="fas fa-calendar-week me-2"></i>@(showCalendarView ? "List View" : "Calendar View")
                            </button>
                            <button class="btn btn-outline-info" @onclick="ExportBookings" disabled="@isProcessing">
                                <i class="fas fa-file-excel me-2"></i>Export
                            </button>
                            <a href="/rooms" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>New Booking
                            </a>
                        </div>
                    </div>

                    <!-- Booking Statistics -->
                    <div class="row mb-4">
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-primary">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-calendar-day" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@todayBookingsCount</h4>
                                    <small>Today's Bookings</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-success">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-check-circle" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@(bookings?.Count(b => b.Status == BookingStatus.Confirmed) ?? 0)</h4>
                                    <small>Confirmed</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-warning">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-clock" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@(bookings?.Count(b => b.Status == BookingStatus.Pending) ?? 0)</h4>
                                    <small>Pending</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-info">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-calendar-week" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@thisWeekBookingsCount</h4>
                                    <small>This Week</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-secondary">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-calendar-alt" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@thisMonthBookingsCount</h4>
                                    <small>This Month</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                            <div class="card text-white bg-dark">
                                <div class="card-body text-center py-3">
                                    <i class="fas fa-percent" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0">@occupancyRate%</h4>
                                    <small>Occupancy Rate</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Status Messages -->
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                                    <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                                    @statusMessage
                                    <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Quick Filters -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-search"></i>
                                        </span>
                                        <input type="text" class="form-control" placeholder="Search bookings..." @bind="searchTerm" @bind:after="ApplyFilters" />
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                                        <option value="">All Status</option>
                                        <option value="@BookingStatus.Confirmed">Confirmed</option>
                                        <option value="@BookingStatus.Pending">Pending</option>
                                        <option value="@BookingStatus.Cancelled">Cancelled</option>
                                        <option value="@BookingStatus.Completed">Completed</option>
                                        <option value="@BookingStatus.InProgress">In Progress</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <select class="form-select" @bind="buildingFilter" @bind:after="ApplyFilters">
                                        <option value="">All Facilities</option>
                                        @if (buildings != null)
                                        {
                                            @foreach (var building in buildings)
                                            {
                                                <option value="@building.Id">@building.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <input type="date" class="form-control" placeholder="From date" @bind="fromDate" @bind:after="ApplyFilters" />
                                </div>
                                <div class="col-md-2">
                                    <input type="date" class="form-control" placeholder="To date" @bind="toDate" @bind:after="ApplyFilters" />
                                </div>
                                <div class="col-md-1">
                                    <button class="btn btn-outline-primary w-100" @onclick="ResetFilters">
                                        <i class="fas fa-undo"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bookings Table -->
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    @if (filteredBookings != null)
                                    {
                                        <span>Bookings (@filteredBookings.Count())</span>
                                    }
                                    else
                                    {
                                        <span>Loading Bookings...</span>
                                    }
                                </h5>
                                <div class="btn-group" role="group">
                                    <button type="button" class="btn @(selectedAction == "approve" ? "btn-success" : "btn-outline-success") btn-sm" 
                                            @onclick="@(() => selectedAction = selectedAction == "approve" ? "" : "approve")">
                                        <i class="fas fa-check"></i> Bulk Approve
                                    </button>
                                    <button type="button" class="btn @(selectedAction == "reject" ? "btn-danger" : "btn-outline-danger") btn-sm" 
                                            @onclick="@(() => selectedAction = selectedAction == "reject" ? "" : "reject")">
                                        <i class="fas fa-times"></i> Bulk Reject
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            @if (filteredBookings == null)
                            {
                                <div class="text-center py-5">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </div>
                            }
                            else if (!filteredBookings.Any())
                            {
                                <div class="text-center py-5">
                                    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                                    <h5>No Bookings Found</h5>
                                    <p class="text-muted">
                                        @if (HasActiveFilters())
                                        {
                                            <span>No bookings match your current filters.</span>
                                        }
                                        else
                                        {
                                            <span>No bookings have been made yet.</span>
                                        }
                                    </p>
                                    @if (HasActiveFilters())
                                    {
                                        <button class="btn btn-outline-primary" @onclick="ResetFilters">
                                            <i class="fas fa-undo me-2"></i> Clear Filters
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>
                                                    <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" />
                                                </th>
                                                <th>Booking ID</th>
                                                <th>Event</th>
                                                <th>Organizer</th>
                                                <th>Room</th>
                                                <th>Date & Time</th>
                                                <th>Attendees</th>
                                                <th>Status</th>
                                                <th class="text-end">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var booking in filteredBookings.Take(pageSize))
                                            {
                                                <tr class="@(selectedBookings.Contains(booking.Id) ? "table-active" : "")">
                                                    <td>
                                                        <input type="checkbox" class="form-check-input" 
                                                               checked="@selectedBookings.Contains(booking.Id)"
                                                               @onchange="() => ToggleSelectBooking(booking.Id)" />
                                                    </td>
                                                    <td class="fw-medium text-primary">BK-@booking.Id.ToString("D4")</td>
                                                    <td>
                                                        <div>
                                                            <div class="fw-medium">@booking.Title</div>
                                                            @if (!string.IsNullOrEmpty(booking.Description))
                                                            {
                                                                <small class="text-muted">@((booking.Description.Length > 50) ? booking.Description.Substring(0, 50) + "..." : booking.Description)</small>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
                                                                <span class="text-white small">@GetUserInitials(booking.User)</span>
                                                            </div>
                                                            <div>
                                                                <div class="small">@booking.User?.FullName</div>
                                                                <small class="text-muted">@booking.User?.Email</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div>
                                                            <div class="fw-medium">@booking.Room?.Name</div>
                                                            <small class="text-muted">@booking.Room?.Building?.Name</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div>
                                                            <div class="fw-medium">@booking.StartDate.ToString("MMM dd, yyyy")</div>
                                                            <small class="text-muted">@booking.StartDate.ToString("HH:mm") - @booking.EndDate.ToString("HH:mm")</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @if (booking.AttendeeCount.HasValue)
                                                        {
                                                            <span class="badge bg-light text-dark">
                                                                <i class="fas fa-users me-1"></i>@booking.AttendeeCount
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">N/A</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span class="badge @GetStatusBadgeClass(booking.Status)">
                                                            <i class="fas @GetStatusIcon(booking.Status) me-1"></i>@booking.Status
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="dropdown">
                                                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                                                    type="button" data-bs-toggle="dropdown">
                                                                Actions
                                                            </button>
                                                            <ul class="dropdown-menu dropdown-menu-end">
                                                                <li><button class="dropdown-item" @onclick="() => ViewBookingDetails(booking)">
                                                                    <i class="fas fa-eye me-2"></i>View Details
                                                                </button></li>
                                                                @if (booking.Status == BookingStatus.Pending)
                                                                {
                                                                    <li><button class="dropdown-item text-success" @onclick="() => ApproveBooking(booking)">
                                                                        <i class="fas fa-check me-2"></i>Approve
                                                                    </button></li>
                                                                    <li><button class="dropdown-item text-danger" @onclick="() => RejectBooking(booking)">
                                                                        <i class="fas fa-times me-2"></i>Reject
                                                                    </button></li>
                                                                }
                                                                @if (booking.Status == BookingStatus.Confirmed)
                                                                {
                                                                    <li><button class="dropdown-item text-warning" @onclick="() => CancelBooking(booking)">
                                                                        <i class="fas fa-ban me-2"></i>Cancel
                                                                    </button></li>
                                                                }
                                                                <li><hr class="dropdown-divider"></li>
                                                                <li><button class="dropdown-item" @onclick="() => SendNotification(booking)">
                                                                    <i class="fas fa-envelope me-2"></i>Send Notification
                                                                </button></li>
                                                                <li><button class="dropdown-item" @onclick="() => ExportBooking(booking)">
                                                                    <i class="fas fa-print me-2"></i>Print Details
                                                                </button></li>
                                                            </ul>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                        @if (filteredBookings != null && filteredBookings.Count() > pageSize)
                        {
                            <div class="card-footer">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Showing @Math.Min(pageSize, filteredBookings.Count()) of @filteredBookings.Count() bookings</small>
                                    <nav>
                                        <ul class="pagination pagination-sm mb-0">
                                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">Previous</button>
                                            </li>
                                            @for (int i = 1; i <= totalPages; i++)
                                            {
                                                <li class="page-item @(currentPage == i ? "active" : "")">
                                                    <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                                                </li>
                                            }
                                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == totalPages)">Next</button>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Selected Actions Bar -->
                    @if (selectedBookings.Any())
                    {
                        <div class="alert alert-info mt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span><strong>@selectedBookings.Count</strong> booking(s) selected</span>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-sm" @onclick="() => BulkApprove()" disabled="@isProcessing">
                                        <i class="fas fa-check me-2"></i>Approve Selected
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => BulkReject()" disabled="@isProcessing">
                                        <i class="fas fa-times me-2"></i>Reject Selected
                                    </button>
                                    <button class="btn btn-secondary btn-sm" @onclick="ClearSelection">
                                        Clear Selection
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="text-center mt-5">
                        <i class="fas fa-lock fa-4x text-muted mb-4"></i>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need administrator or secretary privileges to access booking management.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Booking>? bookings;
    private IEnumerable<Booking>? filteredBookings;
    private IEnumerable<Building>? buildings;
    private bool isProcessing = false;
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private bool showCalendarView = false;
    private string selectedAction = string.Empty;
    private HashSet<int> selectedBookings = new();

    // Statistics
    private int todayBookingsCount = 0;
    private int thisWeekBookingsCount = 0;
    private int thisMonthBookingsCount = 0;
    private int occupancyRate = 0;

    // Filter properties
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string buildingFilter = string.Empty;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 15;
    private int totalPages => filteredBookings != null ? (int)Math.Ceiling((double)filteredBookings.Count() / pageSize) : 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            bookings = await BookingService.GetAllBookingsAsync();
            buildings = await BuildingService.GetAllBuildingsAsync();
            
            CalculateStatistics();
            ApplyFilters();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading data: {ex.Message}", "error");
        }
    }

    private void CalculateStatistics()
    {
        if (bookings == null) return;

        var today = DateTime.Today;
        var startOfWeek = today.AddDays(-(int)today.DayOfWeek);
        var startOfMonth = new DateTime(today.Year, today.Month, 1);

        todayBookingsCount = bookings.Count(b => b.StartDate.Date == today);
        thisWeekBookingsCount = bookings.Count(b => b.StartDate.Date >= startOfWeek && b.StartDate.Date < startOfWeek.AddDays(7));
        thisMonthBookingsCount = bookings.Count(b => b.StartDate.Date >= startOfMonth && b.StartDate.Date < startOfMonth.AddMonths(1));

        // Simple occupancy rate calculation (simplified)
        var totalBookings = bookings.Count();
        var confirmedBookings = bookings.Count(b => b.Status == BookingStatus.Confirmed);
        occupancyRate = totalBookings > 0 ? (int)((double)confirmedBookings / totalBookings * 100) : 0;
    }

    private void ApplyFilters()
    {
        if (bookings == null)
        {
            filteredBookings = null;
            return;
        }

        filteredBookings = bookings;

        // Search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredBookings = filteredBookings.Where(b => 
                b.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (b.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (b.User?.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (b.Room?.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        // Status filter
        if (!string.IsNullOrEmpty(statusFilter) && Enum.TryParse<BookingStatus>(statusFilter, out var status))
        {
            filteredBookings = filteredBookings.Where(b => b.Status == status);
        }

        // Building filter
        if (!string.IsNullOrEmpty(buildingFilter) && int.TryParse(buildingFilter, out int buildingId))
        {
            filteredBookings = filteredBookings.Where(b => b.Room?.BuildingId == buildingId);
        }

        // Date range filter
        if (fromDate.HasValue)
        {
            filteredBookings = filteredBookings.Where(b => b.StartDate.Date >= fromDate.Value.Date);
        }

        if (toDate.HasValue)
        {
            filteredBookings = filteredBookings.Where(b => b.StartDate.Date <= toDate.Value.Date);
        }

        // Sort by most recent first
        filteredBookings = filteredBookings.OrderByDescending(b => b.StartDate);

        // Reset pagination when filters change
        currentPage = 1;
        StateHasChanged();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        statusFilter = string.Empty;
        buildingFilter = string.Empty;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        ApplyFilters();
    }

    private bool HasActiveFilters()
    {
        return !string.IsNullOrEmpty(searchTerm) || 
               !string.IsNullOrEmpty(statusFilter) || 
               !string.IsNullOrEmpty(buildingFilter) || 
               fromDate.HasValue || 
               toDate.HasValue;
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            StateHasChanged();
        }
    }

    private void ToggleCalendarView()
    {
        showCalendarView = !showCalendarView;
        ShowStatusMessage($"Switched to {(showCalendarView ? "calendar" : "list")} view", "success");
    }

    private async Task ExportBookings()
    {
        try
        {
            isProcessing = true;
            StateHasChanged();

            // Simulate export
            await Task.Delay(2000);
            ShowStatusMessage("Booking data exported successfully! Download should start automatically.", "success");
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error exporting bookings: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ViewBookingDetails(Booking booking)
    {
        ShowStatusMessage($"Loading details for booking {booking.Title}...", "success");
        // TODO: Implement booking details modal
    }

    private async Task ApproveBooking(Booking booking)
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                var result = await BookingService.ConfirmBookingAsync(booking.Id, userId);
                if (result)
                {
                    ShowStatusMessage($"Booking '{booking.Title}' approved successfully!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to approve booking.", "error");
                }
            }
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error approving booking: {ex.Message}", "error");
        }
    }

    private async Task RejectBooking(Booking booking)
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                var result = await BookingService.CancelBookingAsync(booking.Id, "Rejected by administrator", userId);
                if (result)
                {
                    ShowStatusMessage($"Booking '{booking.Title}' rejected successfully!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to reject booking.", "error");
                }
            }
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error rejecting booking: {ex.Message}", "error");
        }
    }

    private async Task CancelBooking(Booking booking)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to cancel the booking '{booking.Title}'?"))
        {
            try
            {
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    var result = await BookingService.CancelBookingAsync(booking.Id, "Cancelled by administrator", userId);
                    if (result)
                    {
                        ShowStatusMessage($"Booking '{booking.Title}' cancelled successfully!", "success");
                        await LoadData();
                    }
                    else
                    {
                        ShowStatusMessage("Failed to cancel booking.", "error");
                    }
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error cancelling booking: {ex.Message}", "error");
            }
        }
    }

    private void SendNotification(Booking booking)
    {
        ShowStatusMessage($"Sending notification for booking '{booking.Title}'...", "success");
        // TODO: Implement notification functionality
    }

    private void ExportBooking(Booking booking)
    {
        ShowStatusMessage($"Exporting details for booking '{booking.Title}'...", "success");
        // TODO: Implement individual booking export
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        if (isChecked)
        {
            selectedBookings = filteredBookings?.Take(pageSize).Select(b => b.Id).ToHashSet() ?? new HashSet<int>();
        }
        else
        {
            selectedBookings.Clear();
        }
        StateHasChanged();
    }

    private void ToggleSelectBooking(int bookingId)
    {
        if (selectedBookings.Contains(bookingId))
            selectedBookings.Remove(bookingId);
        else
            selectedBookings.Add(bookingId);
        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedBookings.Clear();
        StateHasChanged();
    }

    private async Task BulkApprove()
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to approve {selectedBookings.Count} selected booking(s)?"))
        {
            try
            {
                isProcessing = true;
                StateHasChanged();

                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    var approvedCount = 0;
                    foreach (var bookingId in selectedBookings)
                    {
                        var result = await BookingService.ConfirmBookingAsync(bookingId, userId);
                        if (result) approvedCount++;
                    }

                    ShowStatusMessage($"{approvedCount} booking(s) approved successfully!", "success");
                    selectedBookings.Clear();
                    await LoadData();
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error during bulk approval: {ex.Message}", "error");
            }
            finally
            {
                isProcessing = false;
                StateHasChanged();
            }
        }
    }

    private async Task BulkReject()
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to reject {selectedBookings.Count} selected booking(s)?"))
        {
            try
            {
                isProcessing = true;
                StateHasChanged();

                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var userId = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrEmpty(userId))
                {
                    var rejectedCount = 0;
                    foreach (var bookingId in selectedBookings)
                    {
                        var result = await BookingService.CancelBookingAsync(bookingId, "Bulk rejected by administrator", userId);
                        if (result) rejectedCount++;
                    }

                    ShowStatusMessage($"{rejectedCount} booking(s) rejected successfully!", "success");
                    selectedBookings.Clear();
                    await LoadData();
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error during bulk rejection: {ex.Message}", "error");
            }
            finally
            {
                isProcessing = false;
                StateHasChanged();
            }
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        if (type == "success")
        {
            Task.Delay(4000).ContinueWith(task =>
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetUserInitials(ApplicationUser? user)
    {
        if (user == null) return "?";
        var initials = $"{user.FirstName?.FirstOrDefault()}{user.LastName?.FirstOrDefault()}";
        return string.IsNullOrEmpty(initials) ? "?" : initials.ToUpper();
    }

    private string GetStatusBadgeClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bg-warning text-dark",
            BookingStatus.Confirmed => "bg-success",
            BookingStatus.InProgress => "bg-primary",
            BookingStatus.Completed => "bg-secondary",
            BookingStatus.Cancelled => "bg-danger",
            _ => "bg-light text-dark"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "fa-clock",
            BookingStatus.Confirmed => "fa-check-circle",
            BookingStatus.InProgress => "fa-play-circle",
            BookingStatus.Completed => "fa-check-square",
            BookingStatus.Cancelled => "fa-times-circle",
            _ => "fa-question-circle"
        };
    }
