@page "/admin/bookings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Booking Management</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="bi bi-calendar-check-fill me-2 text-primary"></i>Booking Management
                </h1>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary">
                        <i class="bi bi-calendar-week me-2"></i>Calendar View
                    </button>
                    <button class="btn btn-outline-info">
                        <i class="bi bi-file-earmark-excel me-2"></i>Export
                    </button>
                    <button class="btn btn-primary">
                        <i class="bi bi-plus-circle-fill me-2"></i>New Booking
                    </button>
                </div>
            </div>

            <!-- Booking Statistics -->
            <div class="row mb-4">
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-primary">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-calendar-event" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">23</h4>
                            <small>Today's Bookings</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-success">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">18</h4>
                            <small>Confirmed</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-warning">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-clock-history" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">5</h4>
                            <small>Pending</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-info">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-arrow-repeat" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">156</h4>
                            <small>This Week</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-secondary">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-calendar-month" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">624</h4>
                            <small>This Month</small>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-6 mb-3">
                    <div class="card text-white bg-dark">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-percent" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">89%</h4>
                            <small>Occupancy Rate</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Filters -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" class="form-control" placeholder="Search bookings..." />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select">
                                <option value="">All Status</option>
                                <option value="confirmed">Confirmed</option>
                                <option value="pending">Pending</option>
                                <option value="cancelled">Cancelled</option>
                                <option value="completed">Completed</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select">
                                <option value="">All Facilities</option>
                                <option value="1">Facility 1</option>
                                <option value="2">Facility 2</option>
                                <option value="3">Facility 3</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input type="date" class="form-control" placeholder="From date" />
                        </div>
                        <div class="col-md-2">
                            <input type="date" class="form-control" placeholder="To date" />
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-outline-primary w-100">
                                <i class="bi bi-funnel-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bookings Table -->
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Bookings (156)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Booking ID</th>
                                    <th>Event</th>
                                    <th>Organizer</th>
                                    <th>Room</th>
                                    <th>Date & Time</th>
                                    <th>Attendees</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 1; i <= 15; i++)
                                {
                                    var statuses = new[] { "confirmed", "pending", "cancelled", "completed" };
                                    var statusClasses = new[] { "success", "warning", "danger", "secondary" };
                                    var statusTexts = new[] { "Confirmed", "Pending", "Cancelled", "Completed" };
                                    var statusIcons = new[] { "check-circle", "clock", "x-circle", "check2-circle" };
                                    
                                    var statusIndex = (i - 1) % 4;
                                    var futureDate = DateTime.Now.AddDays(i - 8);
                                    
                                    <tr>
                                        <td class="fw-medium text-primary">BK-@(1000 + i)</td>
                                        <td>
                                            <div>
                                                <div class="fw-medium">@(GetEventName(i))</div>
                                                <small class="text-muted">@(GetEventType(i))</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
                                                    <span class="text-white small">@(GetInitials(GetOrganizerName(i)))</span>
                                                </div>
                                                <div>
                                                    <div class="small">@(GetOrganizerName(i))</div>
                                                    <small class="text-muted">@(GetDepartment(i))</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <div class="fw-medium">Conference Room @(i % 8 + 1)</div>
                                                <small class="text-muted">Facility @(i % 3 + 1)</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <div class="fw-medium">@futureDate.ToString("MMM dd, yyyy")</div>
                                                <small class="text-muted">@(9 + i % 8):00 - @(11 + i % 8):00</small>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">
                                                <i class="bi bi-people-fill me-1"></i>@(i * 3 + 5)
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-@statusClasses[statusIndex]">
                                                <i class="bi bi-@statusIcons[statusIndex] me-1"></i>@statusTexts[statusIndex]
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="dropdown">
                                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                                        type="button" data-bs-toggle="dropdown">
                                                    Actions
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li><a class="dropdown-item" href="#">
                                                        <i class="bi bi-eye-fill me-2"></i>View Details
                                                    </a></li>
                                                    @if (statusTexts[statusIndex] == "Pending")
                                                    {
                                                        <li><a class="dropdown-item text-success" href="#">
                                                            <i class="bi bi-check-circle me-2"></i>Approve
                                                        </a></li>
                                                        <li><a class="dropdown-item text-danger" href="#">
                                                            <i class="bi bi-x-circle me-2"></i>Reject
                                                        </a></li>
                                                    }
                                                    @if (statusTexts[statusIndex] == "Confirmed")
                                                    {
                                                        <li><a class="dropdown-item" href="#">
                                                            <i class="bi bi-pencil-fill me-2"></i>Modify
                                                        </a></li>
                                                        <li><a class="dropdown-item text-warning" href="#">
                                                            <i class="bi bi-x-circle me-2"></i>Cancel
                                                        </a></li>
                                                    }
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item" href="#">
                                                        <i class="bi bi-envelope-fill me-2"></i>Send Notification
                                                    </a></li>
                                                    <li><a class="dropdown-item" href="#">
                                                        <i class="bi bi-printer-fill me-2"></i>Print Details
                                                    </a></li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Showing 1-15 of 156 bookings</small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item disabled">
                                    <span class="page-link">Previous</span>
                                </li>
                                <li class="page-item active">
                                    <span class="page-link">1</span>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="#">2</a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="#">3</a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="#">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string GetEventName(int index)
    {
        var names = new[] {
            "Team Sprint Planning",
            "Board of Directors Meeting",
            "Product Launch Presentation",
            "Annual Sales Review",
            "Customer Training Session",
            "Technical Workshop",
            "Department Quarterly Review",
            "Strategy Planning Session",
            "New Employee Orientation",
            "Project Kickoff Meeting"
        };
        return names[(index - 1) % names.Length];
    }

    private string GetEventType(int index)
    {
        var types = new[] { "Meeting", "Presentation", "Training", "Workshop", "Review", "Conference" };
        return types[(index - 1) % types.Length];
    }

    private string GetOrganizerName(int index)
    {
        var names = new[] {
            "John Smith", "Sarah Johnson", "Mike Wilson", "Emily Davis", "David Brown",
            "Lisa Anderson", "Robert Taylor", "Jennifer White", "Christopher Lee", "Amanda Miller"
        };
        return names[(index - 1) % names.Length];
    }

    private string GetDepartment(int index)
    {
        var departments = new[] { "IT", "Sales", "HR", "Marketing", "Finance", "Operations" };
        return departments[(index - 1) % departments.Length];
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ');
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name[0].ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }
}