@page "/admin/reports"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Reports & Analytics</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="bi bi-graph-up me-2 text-primary"></i>Reports & Analytics
                </h1>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-calendar-range me-2"></i>Date Range
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Last 7 days</a></li>
                            <li><a class="dropdown-item" href="#">Last 30 days</a></li>
                            <li><a class="dropdown-item" href="#">Last 3 months</a></li>
                            <li><a class="dropdown-item" href="#">Custom range</a></li>
                        </ul>
                    </div>
                    <button class="btn btn-outline-info">
                        <i class="bi bi-file-earmark-excel me-2"></i>Export Data
                    </button>
                    <button class="btn btn-primary">
                        <i class="bi bi-plus-circle-fill me-2"></i>Generate Report
                    </button>
                </div>
            </div>

            <!-- Key Metrics Dashboard -->
            <div class="row mb-4">
                <div class="col-xl-3 col-lg-6 col-md-6 mb-3">
                    <div class="card bg-gradient-primary text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small">Total Bookings</div>
                                    <div class="h4 mb-0">2,847</div>
                                    <div class="small">
                                        <i class="bi bi-arrow-up"></i> 12.5% vs last month
                                    </div>
                                </div>
                                <div class="text-white-50">
                                    <i class="bi bi-calendar-check" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-lg-6 col-md-6 mb-3">
                    <div class="card bg-gradient-success text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small">Revenue Generated</div>
                                    <div class="h4 mb-0">$48,392</div>
                                    <div class="small">
                                        <i class="bi bi-arrow-up"></i> 8.2% vs last month
                                    </div>
                                </div>
                                <div class="text-white-50">
                                    <i class="bi bi-currency-dollar" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-lg-6 col-md-6 mb-3">
                    <div class="card bg-gradient-info text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small">Occupancy Rate</div>
                                    <div class="h4 mb-0">84.7%</div>
                                    <div class="small">
                                        <i class="bi bi-arrow-up"></i> 3.1% vs last month
                                    </div>
                                </div>
                                <div class="text-white-50">
                                    <i class="bi bi-building" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-lg-6 col-md-6 mb-3">
                    <div class="card bg-gradient-warning text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-white-50 small">Customer Satisfaction</div>
                                    <div class="h4 mb-0">4.6/5.0</div>
                                    <div class="small">
                                        <i class="bi bi-arrow-up"></i> 0.3 vs last month
                                    </div>
                                </div>
                                <div class="text-white-50">
                                    <i class="bi bi-star-fill" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Report Categories -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Available Report Categories</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-primary h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-calendar-week text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Booking Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">Analyze booking patterns, peak times, and utilization rates</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-primary btn-sm">Generate</button>
                                                <button class="btn btn-outline-secondary btn-sm">View Sample</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-success h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-currency-dollar text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Financial Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">Revenue analysis, cost breakdown, and profit margins</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-success btn-sm">Generate</button>
                                                <button class="btn btn-outline-secondary btn-sm">View Sample</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-info h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-info rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-building text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Facility Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">Facility performance, maintenance costs, and capacity analysis</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-info btn-sm">Generate</button>
                                                <button class="btn btn-outline-secondary btn-sm">View Sample</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-warning h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-people text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Customer Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">Customer behavior, satisfaction scores, and usage patterns</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-warning btn-sm">Generate</button>
                                                <button class="btn btn-outline-secondary btn-sm">View Sample</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-secondary h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-graph-up text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Performance Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">KPI tracking, goal achievement, and trend analysis</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-secondary btn-sm">Generate</button>
                                                <button class="btn btn-outline-secondary btn-sm">View Sample</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-lg-6 col-md-12 mb-3">
                                    <div class="card border-left-dark h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-file-text text-white"></i>
                                                </div>
                                                <h6 class="mb-0">Custom Reports</h6>
                                            </div>
                                            <p class="text-muted small mb-3">Build custom reports with your specific data requirements</p>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-dark btn-sm">Create Custom</button>
                                                <button class="btn btn-outline-secondary btn-sm">Templates</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Reports & Analytics -->
            <div class="row">
                <div class="col-xl-8 col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">Recent Reports</h5>
                                <button class="btn btn-outline-primary btn-sm">View All</button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Report Name</th>
                                            <th>Category</th>
                                            <th>Generated By</th>
                                            <th>Date</th>
                                            <th>Size</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 1; i <= 8; i++)
                                        {
                                            var categories = new[] { "Booking", "Financial", "Facility", "Customer", "Performance" };
                                            var categoryClasses = new[] { "primary", "success", "info", "warning", "secondary" };
                                            var categoryIndex = (i - 1) % categories.Length;
                                            var generatedDate = DateTime.Now.AddDays(-i * 2);
                                            
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <i class="bi bi-file-earmark-text text-muted me-2"></i>
                                                        <div>
                                                            <div class="fw-medium">@GetReportName(i)</div>
                                                            <small class="text-muted">Auto-generated report</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-@categoryClasses[categoryIndex]">
                                                        @categories[categoryIndex]
                                                    </span>
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                                            <span class="text-white small">SJ</span>
                                                        </div>
                                                        <small>Sarah Johnson</small>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div>
                                                        <div class="small">@generatedDate.ToString("MMM dd, yyyy")</div>
                                                        <small class="text-muted">@generatedDate.ToString("HH:mm")</small>
                                                    </div>
                                                </td>
                                                <td class="small text-muted">@((i * 0.8 + 1.2).ToString("F1")) MB</td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button class="btn btn-outline-primary" title="View">
                                                            <i class="bi bi-eye-fill"></i>
                                                        </button>
                                                        <button class="btn btn-outline-success" title="Download">
                                                            <i class="bi bi-download"></i>
                                                        </button>
                                                        <button class="btn btn-outline-secondary" title="Share">
                                                            <i class="bi bi-share"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4 col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Quick Analytics</h5>
                        </div>
                        <div class="card-body">
                            <!-- Placeholder for chart -->
                            <div class="bg-light rounded p-4 text-center mb-3" style="height: 200px;">
                                <div class="d-flex align-items-center justify-content-center h-100">
                                    <div>
                                        <i class="bi bi-graph-up text-muted" style="font-size: 3rem;"></i>
                                        <div class="mt-2 text-muted">
                                            <strong>Occupancy Trends</strong>
                                            <div class="small">Last 30 days visualization</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="border-end">
                                        <div class="h6 mb-0 text-primary">84.7%</div>
                                        <small class="text-muted">Average</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="h6 mb-0 text-success">92.1%</div>
                                    <small class="text-muted">Peak Day</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Export Options</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-primary">
                                    <i class="bi bi-file-earmark-pdf-fill me-2"></i>Export as PDF
                                </button>
                                <button class="btn btn-outline-success">
                                    <i class="bi bi-file-earmark-excel-fill me-2"></i>Export as Excel
                                </button>
                                <button class="btn btn-outline-info">
                                    <i class="bi bi-file-earmark-text-fill me-2"></i>Export as CSV
                                </button>
                                <button class="btn btn-outline-secondary">
                                    <i class="bi bi-envelope-fill me-2"></i>Email Report
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string GetReportName(int index)
    {
        var reportNames = new[] {
            "Monthly Booking Summary",
            "Q3 Financial Analysis",
            "Facility Utilization Report",
            "Customer Satisfaction Survey",
            "Peak Hours Analysis",
            "Revenue Breakdown Report",
            "Maintenance Cost Analysis",
            "Event Performance Metrics",
            "Occupancy Rate Trends",
            "Customer Behavior Analysis"
        };
        return reportNames[(index - 1) % reportNames.Length];
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }
}