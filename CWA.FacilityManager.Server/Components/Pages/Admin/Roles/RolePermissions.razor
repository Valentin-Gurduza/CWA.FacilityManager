@page "/admin/roles/{roleId}/permissions"
@using CWA.FacilityManager.Application.DTOs.UserManagement
@using CWA.FacilityManager.Application.Interfaces.UserManagement
@using Microsoft.AspNetCore.Authorization
@inject IRoleManagementService RoleManagementService
@inject IPermissionService PermissionService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@attribute [Authorize(Policy = "ActiveAdmin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Manage Role Permissions</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="/admin/roles" class="text-decoration-none">Role Management</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a href="/admin/roles/@RoleId" class="text-decoration-none">@(currentRole?.Name ?? "Role")</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">Permissions</li>
                        </ol>
                    </nav>
                    <h1 class="h3">
                        <i class="bi bi-key me-2"></i>@(currentRole?.IsSystemRole == true ? "View" : "Manage") Permissions: @(currentRole?.Name ?? "Loading...")
                    </h1>
                </div>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="@(() => Navigation.NavigateTo($"/admin/roles/{RoleId}"))">
                        <i class="bi bi-arrow-left me-1"></i>Back to Role
                    </button>
                    @if (currentRole?.IsSystemRole != true && hasChanges)
                    {
                        <button class="btn btn-success me-2" @onclick="SaveChanges" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-1"></i>
                            }
                            Save Changes
                        </button>
                        <button class="btn btn-outline-warning" @onclick="ResetChanges">
                            <i class="bi bi-arrow-clockwise me-1"></i>Reset
                        </button>
                    }
                </div>
            </div>

            @if (isLoading)
            {
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (currentRole == null)
            {
                <div class="alert alert-danger">
                    <h5>Role Not Found</h5>
                    <p>The role you're looking for could not be found.</p>
                    <a href="/admin/roles" class="btn btn-primary">Back to Roles</a>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-lg-9">
                        @if (currentRole.IsSystemRole)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>System Role:</strong> This is a system role. Permissions cannot be modified but can be viewed.
                            </div>
                        }
                        else if (hasChanges)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <strong>Unsaved Changes:</strong> You have made changes to the permissions. Don't forget to save your changes.
                            </div>
                        }

                        <!-- Permission Controls -->
                        @if (!currentRole.IsSystemRole)
                        {
                            <div class="card mb-4">
                                <div class="card-body">
                                    <div class="row g-3 align-items-center">
                                        <div class="col-md-6">
                                            <div class="input-group">
                                                <span class="input-group-text">
                                                    <i class="bi bi-search"></i>
                                                </span>
                                                <input type="text" class="form-control" placeholder="Search permissions..." 
                                                       @bind="searchTerm" @onkeypress="OnSearchKeyPress" />
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <select class="form-select" @bind="selectedModule" @bind:after="FilterPermissions">
                                                <option value="">All Modules</option>
                                                @foreach (var module in availableModules)
                                                {
                                                    <option value="@module">@GetModuleDisplayName(module)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="btn-group w-100" role="group">
                                                <button type="button" class="btn btn-outline-primary" @onclick="SelectAllVisible">
                                                    <i class="bi bi-check-all me-1"></i>Select All
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllVisible">
                                                    <i class="bi bi-x-square me-1"></i>Deselect All
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Permissions by Module -->
                        @if (filteredGroups.Any())
                        {
                            @foreach (var group in filteredGroups)
                            {
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h5 class="mb-0">
                                                <i class="bi @GetModuleIcon(group.Module) me-2"></i>
                                                @group.ModuleDisplayName
                                                <span class="badge bg-secondary ms-2">@group.Resources.Sum(r => r.Permissions.Count)</span>
                                            </h5>
                                            @if (!currentRole.IsSystemRole)
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-primary" @onclick="() => ToggleModule(group.Module, true)">
                                                        <i class="bi bi-check-square me-1"></i>Select All
                                                    </button>
                                                    <button type="button" class="btn btn-outline-secondary" @onclick="() => ToggleModule(group.Module, false)">
                                                        <i class="bi bi-square me-1"></i>Deselect All
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        @foreach (var resource in group.Resources)
                                        {
                                            <div class="mb-4">
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <h6 class="text-muted mb-0">
                                                        <i class="bi bi-folder me-1"></i>@resource.ResourceDisplayName
                                                        <span class="badge bg-light text-dark ms-2">@resource.Permissions.Count</span>
                                                    </h6>
                                                    @if (!currentRole.IsSystemRole)
                                                    {
                                                        <div class="btn-group btn-group-sm">
                                                            <button type="button" class="btn btn-outline-primary" @onclick="() => ToggleResource(group.Module, resource.Resource, true)">
                                                                <i class="bi bi-check-square me-1"></i>All
                                                            </button>
                                                            <button type="button" class="btn btn-outline-secondary" @onclick="() => ToggleResource(group.Module, resource.Resource, false)">
                                                                <i class="bi bi-square me-1"></i>None
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="row g-2">
                                                    @foreach (var permission in resource.Permissions)
                                                    {
                                                        <div class="col-md-4 col-lg-3">
                                                            <div class="card border @(permission.IsGranted ? "border-success bg-success-subtle" : "border-light")">
                                                                <div class="card-body p-3">
                                                                    <div class="form-check">
                                                                        <input type="checkbox" 
                                                                               class="form-check-input" 
                                                                               id="permission_@permission.Id"
                                                                               checked="@permission.IsGranted"
                                                                               disabled="@currentRole.IsSystemRole"
                                                                               @onchange="(e) => TogglePermission(permission, (bool)(e.Value ?? false))" />
                                                                        <label class="form-check-label w-100" for="permission_@permission.Id">
                                                                            <div class="fw-bold">@permission.Action</div>
                                                                            @if (!string.IsNullOrEmpty(permission.Description))
                                                                            {
                                                                                <small class="text-muted">@permission.Description</small>
                                                                            }
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-search display-4 text-muted"></i>
                                <h5 class="mt-3">No permissions found</h5>
                                <p class="text-muted">Try adjusting your search criteria or module filter.</p>
                            </div>
                        }
                    </div>
                    
                    <div class="col-lg-3">
                        <!-- Summary Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6 class="card-title mb-0">
                                    <i class="bi bi-graph-up me-2"></i>Permission Summary
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="row text-center">
                                    <div class="col-6">
                                        <div class="border-end">
                                            <h4 class="text-success mb-1">@selectedPermissionIds.Count</h4>
                                            <small class="text-muted">Granted</small>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <h4 class="text-muted mb-1">@totalPermissions</h4>
                                        <small class="text-muted">Total</small>
                                    </div>
                                </div>
                                
                                @if (totalPermissions > 0)
                                {
                                    <div class="mt-3">
                                        <div class="progress">
                                            <div class="progress-bar bg-success" role="progressbar" 
                                                 style="width: @(((double)selectedPermissionIds.Count / totalPermissions) * 100)%"
                                                 aria-valuenow="@selectedPermissionIds.Count" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="@totalPermissions">
                                                @Math.Round(((double)selectedPermissionIds.Count / totalPermissions) * 100, 1)%
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Changes Summary -->
                        @if (hasChanges && !currentRole.IsSystemRole)
                        {
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h6 class="card-title mb-0 text-warning">
                                        <i class="bi bi-exclamation-triangle me-2"></i>Pending Changes
                                    </h6>
                                </div>
                                <div class="card-body">
                                    @if (addedPermissions.Any())
                                    {
                                        <div class="mb-3">
                                            <small class="text-success fw-bold">Added (@addedPermissions.Count):</small>
                                            <div class="mt-1">
                                                @foreach (var permission in addedPermissions.Take(3))
                                                {
                                                    <span class="badge bg-success-subtle text-success d-block mb-1">@permission.DisplayName</span>
                                                }
                                                @if (addedPermissions.Count > 3)
                                                {
                                                    <small class="text-muted">and @(addedPermissions.Count - 3) more...</small>
                                                }
                                            </div>
                                        </div>
                                    }
                                    
                                    @if (removedPermissions.Any())
                                    {
                                        <div class="mb-3">
                                            <small class="text-danger fw-bold">Removed (@removedPermissions.Count):</small>
                                            <div class="mt-1">
                                                @foreach (var permission in removedPermissions.Take(3))
                                                {
                                                    <span class="badge bg-danger-subtle text-danger d-block mb-1">@permission.DisplayName</span>
                                                }
                                                @if (removedPermissions.Count > 3)
                                                {
                                                    <small class="text-muted">and @(removedPermissions.Count - 3) more...</small>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Module Summary -->
                        <div class="card">
                            <div class="card-header">
                                <h6 class="card-title mb-0">
                                    <i class="bi bi-collection me-2"></i>By Module
                                </h6>
                            </div>
                            <div class="card-body">
                                @foreach (var module in moduleStats)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small>@GetModuleDisplayName(module.Key)</small>
                                        <span class="badge bg-secondary">@module.Value.granted/@module.Value.total</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Success/Error Messages -->
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show" role="alert">
            <div class="toast-header bg-success text-white">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong class="me-auto">Success</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => successMessage = string.Empty"></button>
            </div>
            <div class="toast-body">
                @successMessage
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show" role="alert">
            <div class="toast-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => errorMessage = string.Empty"></button>
            </div>
            <div class="toast-body">
                @errorMessage
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string RoleId { get; set; } = string.Empty;
    
    private RoleDto? currentRole;
    private List<PermissionGroupDto> allGroups = new();
    private List<PermissionGroupDto> filteredGroups = new();
    private HashSet<int> selectedPermissionIds = new();
    private HashSet<int> originalPermissionIds = new();
    private string searchTerm = string.Empty;
    private string selectedModule = string.Empty;
    private List<string> availableModules = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;
    private int totalPermissions = 0;
    private Dictionary<string, (int granted, int total)> moduleStats = new();
    
    private bool hasChanges => !selectedPermissionIds.SetEquals(originalPermissionIds);
    private List<PermissionDto> addedPermissions => 
        allGroups.SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
               .Where(p => selectedPermissionIds.Contains(p.Id) && !originalPermissionIds.Contains(p.Id))
               .ToList();
    private List<PermissionDto> removedPermissions => 
        allGroups.SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
               .Where(p => !selectedPermissionIds.Contains(p.Id) && originalPermissionIds.Contains(p.Id))
               .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoleAndPermissions();
    }

    private async Task LoadRoleAndPermissions()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // Load role and its current permissions
            currentRole = await RoleManagementService.GetRoleByIdAsync(RoleId);
            if (currentRole == null) return;

            // Load all permissions grouped
            allGroups = (await PermissionService.GetPermissionsGroupedAsync()).ToList();
            
            // Set display names
            foreach (var group in allGroups)
            {
                group.ModuleDisplayName = GetModuleDisplayName(group.Module);
                foreach (var resource in group.Resources)
                {
                    resource.ResourceDisplayName = GetResourceDisplayName(resource.Resource);
                }
            }

            // Get available modules
            availableModules = allGroups.Select(g => g.Module).Distinct().OrderBy(m => m).ToList();
            
            // Set current role permissions
            originalPermissionIds = currentRole.Permissions.Select(p => p.Id).ToHashSet();
            selectedPermissionIds = new HashSet<int>(originalPermissionIds);
            
            totalPermissions = allGroups.SelectMany(g => g.Resources.SelectMany(r => r.Permissions)).Count();
            
            // Update permission granted status
            UpdatePermissionGrantedStatus();
            
            // Apply initial filtering
            FilterPermissions();
            
            // Calculate module stats
            CalculateModuleStats();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading role permissions: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void UpdatePermissionGrantedStatus()
    {
        foreach (var group in allGroups)
        {
            foreach (var resource in group.Resources)
            {
                foreach (var permission in resource.Permissions)
                {
                    permission.IsGranted = selectedPermissionIds.Contains(permission.Id);
                }
            }
        }
    }

    private void FilterPermissions()
    {
        var filteredGroupsQuery = allGroups.AsEnumerable();
        
        // Filter by module
        if (!string.IsNullOrEmpty(selectedModule))
        {
            filteredGroupsQuery = filteredGroupsQuery.Where(g => g.Module == selectedModule);
        }
        
        // Filter by search term
        if (!string.IsNullOrEmpty(searchTerm))
        {
            filteredGroupsQuery = filteredGroupsQuery.Select(g => new PermissionGroupDto
            {
                Module = g.Module,
                ModuleDisplayName = g.ModuleDisplayName,
                Resources = g.Resources.Select(r => new PermissionResourceDto
                {
                    Resource = r.Resource,
                    ResourceDisplayName = r.ResourceDisplayName,
                    Permissions = r.Permissions.Where(p => 
                        p.DisplayName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        p.Action.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        (p.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                    ).ToList()
                }).Where(r => r.Permissions.Any()).ToList()
            }).Where(g => g.Resources.Any());
        }
        
        filteredGroups = filteredGroupsQuery.ToList();
        StateHasChanged();
    }

    private async Task OnSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            FilterPermissions();
        }
    }

    private void TogglePermission(PermissionDto permission, bool isGranted)
    {
        if (currentRole?.IsSystemRole == true) return;
        
        if (isGranted)
        {
            selectedPermissionIds.Add(permission.Id);
        }
        else
        {
            selectedPermissionIds.Remove(permission.Id);
        }
        
        permission.IsGranted = isGranted;
        CalculateModuleStats();
        StateHasChanged();
    }

    private void ToggleModule(string module, bool isGranted)
    {
        if (currentRole?.IsSystemRole == true) return;
        
        var modulePermissions = allGroups
            .Where(g => g.Module == module)
            .SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
            .ToList();
        
        foreach (var permission in modulePermissions)
        {
            if (isGranted)
            {
                selectedPermissionIds.Add(permission.Id);
            }
            else
            {
                selectedPermissionIds.Remove(permission.Id);
            }
            permission.IsGranted = isGranted;
        }
        
        CalculateModuleStats();
        StateHasChanged();
    }

    private void ToggleResource(string module, string resource, bool isGranted)
    {
        if (currentRole?.IsSystemRole == true) return;
        
        var resourcePermissions = allGroups
            .Where(g => g.Module == module)
            .SelectMany(g => g.Resources.Where(r => r.Resource == resource).SelectMany(r => r.Permissions))
            .ToList();
        
        foreach (var permission in resourcePermissions)
        {
            if (isGranted)
            {
                selectedPermissionIds.Add(permission.Id);
            }
            else
            {
                selectedPermissionIds.Remove(permission.Id);
            }
            permission.IsGranted = isGranted;
        }
        
        CalculateModuleStats();
        StateHasChanged();
    }

    private void SelectAllVisible()
    {
        if (currentRole?.IsSystemRole == true) return;
        
        var visiblePermissions = filteredGroups
            .SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
            .ToList();
        
        foreach (var permission in visiblePermissions)
        {
            selectedPermissionIds.Add(permission.Id);
            permission.IsGranted = true;
        }
        
        CalculateModuleStats();
        StateHasChanged();
    }

    private void DeselectAllVisible()
    {
        if (currentRole?.IsSystemRole == true) return;
        
        var visiblePermissions = filteredGroups
            .SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
            .ToList();
        
        foreach (var permission in visiblePermissions)
        {
            selectedPermissionIds.Remove(permission.Id);
            permission.IsGranted = false;
        }
        
        CalculateModuleStats();
        StateHasChanged();
    }

    private void CalculateModuleStats()
    {
        moduleStats.Clear();
        
        foreach (var module in availableModules)
        {
            var modulePermissions = allGroups
                .Where(g => g.Module == module)
                .SelectMany(g => g.Resources.SelectMany(r => r.Permissions))
                .ToList();
            
            var granted = modulePermissions.Count(p => selectedPermissionIds.Contains(p.Id));
            var total = modulePermissions.Count;
            
            moduleStats[module] = (granted, total);
        }
    }

    private async Task SaveChanges()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var result = await RoleManagementService.UpdateRolePermissionsAsync(
                RoleId, 
                selectedPermissionIds.ToList(), 
                "Admin" // TODO: Get current user
            );
            
            if (result)
            {
                originalPermissionIds = new HashSet<int>(selectedPermissionIds);
                successMessage = $"Permissions for role '{currentRole!.Name}' have been updated successfully.";
                
                // Reload the role to get updated permissions
                await LoadRoleAndPermissions();
            }
            else
            {
                errorMessage = "Failed to update role permissions.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving permissions: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void ResetChanges()
    {
        selectedPermissionIds = new HashSet<int>(originalPermissionIds);
        UpdatePermissionGrantedStatus();
        CalculateModuleStats();
        StateHasChanged();
    }

    private string GetModuleDisplayName(string module)
    {
        return module switch
        {
            "UserManagement" => "User Management",
            "FacilityManagement" => "Facility Management",
            "BookingManagement" => "Booking Management",
            "EventManagement" => "Event Management",
            "ReportManagement" => "Report Management",
            "SystemManagement" => "System Management",
            _ => module
        };
    }

    private string GetResourceDisplayName(string resource)
    {
        return resource switch
        {
            "Users" => "Users",
            "Roles" => "Roles",
            "Permissions" => "Permissions",
            "Facilities" => "Facilities",
            "Rooms" => "Rooms",
            "Bookings" => "Bookings",
            "Events" => "Events",
            "Reports" => "Reports",
            "Configuration" => "Configuration",
            _ => resource
        };
    }

    private string GetModuleIcon(string module)
    {
        return module switch
        {
            "UserManagement" => "bi-people",
            "FacilityManagement" => "bi-building",
            "BookingManagement" => "bi-calendar-check",
            "EventManagement" => "bi-calendar-event",
            "ReportManagement" => "bi-graph-up",
            "SystemManagement" => "bi-gear",
            _ => "bi-collection"
        };
    }
}