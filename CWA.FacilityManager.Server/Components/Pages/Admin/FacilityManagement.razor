@page "/admin/facilities"
@using Microsoft.AspNetCore.Authorization
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode InteractiveServer
@inject IBuildingService BuildingService
@inject IRoomService RoomService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Facility Management</PageTitle>

<AuthorizeView Policy="ActiveAdminOrSecretary">
    <Authorized>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h3">
                            <i class="fas fa-building me-2 text-primary"></i>Facility Management
                        </h1>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary" @onclick="ExportToPdf" disabled="@isProcessing">
                                <i class="fas fa-file-pdf me-2"></i>Export PDF
                            </button>
                            <button class="btn btn-primary" @onclick="ShowAddBuildingModal">
                                <i class="fas fa-plus me-2"></i>Add New Facility
                            </button>
                        </div>
                    </div>

                    <!-- Statistics Cards -->
                    <div class="row mb-4">
                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-primary border-4 shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">
                                                Total Facilities</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(buildings?.Count() ?? 0)</div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-building text-primary" style="font-size: 2rem;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-success border-4 shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-success text-uppercase mb-1">
                                                Active Facilities</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(buildings?.Count(b => b.IsActive) ?? 0)</div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-check-circle text-success" style="font-size: 2rem;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-info border-4 shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-info text-uppercase mb-1">
                                                Total Rooms</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@totalRooms</div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-door-open text-info" style="font-size: 2rem;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-warning border-4 shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-warning text-uppercase mb-1">
                                                Inactive Facilities</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(buildings?.Count(b => !b.IsActive) ?? 0)</div>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-exclamation-triangle text-warning" style="font-size: 2rem;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Status Messages -->
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                                    <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                                    @statusMessage
                                    <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Search and Filter Bar -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-search"></i>
                                        </span>
                                        <input type="text" class="form-control" placeholder="Search facilities..." @bind="searchTerm" @bind:after="ApplyFilters" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                                        <option value="">All Status</option>
                                        <option value="active">Active</option>
                                        <option value="inactive">Inactive</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select" @bind="roomCountFilter" @bind:after="ApplyFilters">
                                        <option value="">All Sizes</option>
                                        <option value="small">Small (1-5 rooms)</option>
                                        <option value="medium">Medium (6-15 rooms)</option>
                                        <option value="large">Large (16+ rooms)</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-outline-primary w-100" @onclick="ResetFilters">
                                        <i class="fas fa-undo me-2"></i>Reset
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Facilities Grid -->
                    <div class="row">
                        @if (filteredBuildings == null)
                        {
                            <div class="col-12 text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        }
                        else if (!filteredBuildings.Any())
                        {
                            <div class="col-12">
                                <div class="alert alert-info text-center">
                                    <div class="mb-3">
                                        <i class="fas fa-building fa-4x text-muted"></i>
                                    </div>
                                    <h4>No Facilities Found</h4>
                                    <p>
                                        @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(roomCountFilter))
                                        {
                                            <span>No facilities match your current filters.</span>
                                        }
                                        else
                                        {
                                            <span>Start by adding your first facility to the system!</span>
                                        }
                                    </p>
                                    @if (string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(statusFilter) && string.IsNullOrEmpty(roomCountFilter))
                                    {
                                        <button class="btn btn-primary btn-lg" @onclick="ShowAddBuildingModal">
                                            <i class="fas fa-plus me-2"></i> Add Your First Facility
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary" @onclick="ResetFilters">
                                            <i class="fas fa-undo me-2"></i> Clear Filters
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var building in filteredBuildings)
                            {
                                <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                                    <div class="card shadow-sm h-100 facility-card">
                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                            <i class="fas fa-building text-muted" style="font-size: 4rem;"></i>
                                        </div>
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-0">@building.Name</h5>
                                                <span class="badge @(building.IsActive ? "bg-success" : "bg-secondary")">
                                                    @(building.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </div>
                                            <p class="card-text text-muted">
                                                <small><i class="fas fa-map-marker-alt me-1"></i>@building.Address</small>
                                            </p>
                                            @if (!string.IsNullOrEmpty(building.Description))
                                            {
                                                <p class="card-text">
                                                    <small>@((building.Description.Length > 80) ? building.Description.Substring(0, 80) + "..." : building.Description)</small>
                                                </p>
                                            }
                                            <div class="mb-2">
                                                <small class="text-muted">
                                                    <i class="fas fa-door-open me-1"></i>@building.Rooms.Count() Rooms
                                                    <i class="fas fa-users ms-2 me-1"></i>@building.Rooms.Sum(r => r.Capacity) Total Capacity
                                                </small>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-outline-primary btn-sm" title="View Details" @onclick="() => ViewBuildingDetails(building)">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm" title="Edit" @onclick="() => EditBuilding(building)">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-outline-info btn-sm" title="Manage Rooms" @onclick="() => ManageRooms(building)">
                                                        <i class="fas fa-door-open"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" title="Delete" @onclick="() => DeleteBuilding(building)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                                <small class="text-muted">@building.CreatedAt.ToString("MMM dd, yyyy")</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Add/Edit Building Modal -->
        @if (showBuildingModal)
        {
            <!-- Modal Backdrop -->
            <div class="modal-backdrop fade show" @onclick="CloseModal"></div>
            
            <!-- Modal Dialog -->
            <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="fas @(isEditMode ? "fa-edit" : "fa-plus") me-2"></i>
                                @(isEditMode ? "Edit Facility" : "Add New Facility")
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseModal" aria-label="Close"></button>
                        </div>
                        
                        <EditForm Model="buildingModel" OnValidSubmit="SaveBuilding" Context="editContext">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <ValidationSummary class="text-danger mb-3" />
                                
                                <!-- Building Name -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-building me-1"></i>Facility Name <span class="text-danger">*</span>
                                    </label>
                                    <InputText class="form-control form-control-lg" @bind-Value="buildingModel.Name" 
                                               placeholder="Enter facility name (e.g., Main Conference Center, Training Building)" />
                                    <ValidationMessage For="() => buildingModel.Name" class="text-danger" />
                                </div>

                                <!-- Address -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-map-marker-alt me-1"></i>Address <span class="text-danger">*</span>
                                    </label>
                                    <InputText class="form-control" @bind-Value="buildingModel.Address" 
                                               placeholder="Enter full address of the facility" />
                                    <ValidationMessage For="() => buildingModel.Address" class="text-danger" />
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-align-left me-1"></i>Description
                                    </label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="buildingModel.Description" 
                                                   placeholder="Describe the facility, its features, and purpose..." />
                                    <div class="form-text">Optional detailed description of the facility</div>
                                </div>

                                <!-- Status -->
                                <div class="mb-3">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="buildingModel.IsActive" id="isActive" />
                                        <label class="form-check-label fw-bold" for="isActive">
                                            <i class="fas fa-toggle-on me-1"></i>Active Facility
                                        </label>
                                        <div class="form-text">Only active facilities will be available for room bookings</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                                    <i class="fas fa-times me-1"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                    @if (isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="fas @(isEditMode ? "fa-save" : "fa-plus") me-1"></i>
                                    @(isEditMode ? "Update Facility" : "Create Facility")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }

        <!-- Building Details Modal -->
        @if (showDetailsModal && selectedBuilding != null)
        {
            <!-- Modal Backdrop -->
            <div class="modal-backdrop fade show" @onclick="CloseDetailsModal"></div>
            
            <!-- Modal Dialog -->
            <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">
                                <i class="fas fa-building me-2"></i>
                                Facility Details: @selectedBuilding.Name
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseDetailsModal" aria-label="Close"></button>
                        </div>
                        
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6><i class="fas fa-info-circle me-2"></i>Basic Information</h6>
                                    <table class="table table-sm">
                                        <tr>
                                            <td><strong>Name:</strong></td>
                                            <td>@selectedBuilding.Name</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Address:</strong></td>
                                            <td>@selectedBuilding.Address</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Status:</strong></td>
                                            <td>
                                                <span class="badge @(selectedBuilding.IsActive ? "bg-success" : "bg-secondary")">
                                                    @(selectedBuilding.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Created:</strong></td>
                                            <td>@selectedBuilding.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <h6><i class="fas fa-chart-bar me-2"></i>Statistics</h6>
                                    <table class="table table-sm">
                                        <tr>
                                            <td><strong>Total Rooms:</strong></td>
                                            <td>@selectedBuilding.Rooms.Count()</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Active Rooms:</strong></td>
                                            <td>@selectedBuilding.Rooms.Count(r => r.IsActive)</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Capacity:</strong></td>
                                            <td>@selectedBuilding.Rooms.Sum(r => r.Capacity) people</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Average Room Size:</strong></td>
                                            <td>@(selectedBuilding.Rooms.Any() ? Math.Round(selectedBuilding.Rooms.Average(r => r.Capacity), 1) : 0) people</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(selectedBuilding.Description))
                            {
                                <div class="row mt-3">
                                    <div class="col-12">
                                        <h6><i class="fas fa-align-left me-2"></i>Description</h6>
                                        <p>@selectedBuilding.Description</p>
                                    </div>
                                </div>
                            }

                            <div class="row mt-3">
                                <div class="col-12">
                                    <h6><i class="fas fa-door-open me-2"></i>Rooms in this Facility</h6>
                                    @if (selectedBuilding.Rooms.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>Room Name</th>
                                                        <th>Room Number</th>
                                                        <th>Capacity</th>
                                                        <th>Activity</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var room in selectedBuilding.Rooms.OrderBy(r => r.Name))
                                                    {
                                                        <tr>
                                                            <td>@room.Name</td>
                                                            <td>@room.RoomNumber</td>
                                                            <td>@room.Capacity</td>
                                                            <td>@room.Activity</td>
                                                            <td>
                                                                <span class="badge @(room.IsActive ? "bg-success" : "bg-secondary")">
                                                                    @(room.IsActive ? "Active" : "Inactive")
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info">
                                            <i class="fas fa-info-circle"></i> No rooms have been added to this facility yet.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">
                                <i class="fas fa-times me-1"></i> Close
                            </button>
                            <button type="button" class="btn btn-primary" @onclick="() => EditBuilding(selectedBuilding)">
                                <i class="fas fa-edit me-1"></i> Edit Facility
                            </button>
                            <button type="button" class="btn btn-info" @onclick="() => ManageRooms(selectedBuilding)">
                                <i class="fas fa-door-open me-1"></i> Manage Rooms
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="text-center mt-5">
                        <i class="fas fa-lock fa-4x text-muted mb-4"></i>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need administrator or secretary privileges to access facility management.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Building>? buildings;
    private IEnumerable<Building>? filteredBuildings;
    private Building? selectedBuilding;
    private bool showBuildingModal = false;
    private bool showDetailsModal = false;
    private bool isEditMode = false;
    private bool isProcessing = false;
    private Building buildingModel = new Building();
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private int totalRooms = 0;

    // Filter properties
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string roomCountFilter = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            buildings = await BuildingService.GetAllBuildingsAsync();
            
            // Calculate total rooms across all buildings
            if (buildings != null)
            {
                totalRooms = buildings.SelectMany(b => b.Rooms).Count();
            }
            
            ApplyFilters();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading data: {ex.Message}", "error");
        }
    }

    private void ApplyFilters()
    {
        if (buildings == null)
        {
            filteredBuildings = null;
            return;
        }

        filteredBuildings = buildings;

        // Search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredBuildings = filteredBuildings.Where(b => 
                b.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.Address.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (b.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        // Status filter
        if (!string.IsNullOrEmpty(statusFilter))
        {
            filteredBuildings = statusFilter switch
            {
                "active" => filteredBuildings.Where(b => b.IsActive),
                "inactive" => filteredBuildings.Where(b => !b.IsActive),
                _ => filteredBuildings
            };
        }

        // Room count filter
        if (!string.IsNullOrEmpty(roomCountFilter))
        {
            filteredBuildings = roomCountFilter switch
            {
                "small" => filteredBuildings.Where(b => b.Rooms.Count() <= 5),
                "medium" => filteredBuildings.Where(b => b.Rooms.Count() >= 6 && b.Rooms.Count() <= 15),
                "large" => filteredBuildings.Where(b => b.Rooms.Count() >= 16),
                _ => filteredBuildings
            };
        }

        StateHasChanged();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        statusFilter = string.Empty;
        roomCountFilter = string.Empty;
        ApplyFilters();
    }

    private void ShowAddBuildingModal()
    {
        buildingModel = new Building 
        { 
            Id = 0,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };
        isEditMode = false;
        showBuildingModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void EditBuilding(Building building)
    {
        buildingModel = new Building
        {
            Id = building.Id,
            Name = building.Name,
            Address = building.Address,
            Description = building.Description,
            IsActive = building.IsActive,
            CreatedAt = building.CreatedAt
        };
        isEditMode = true;
        showBuildingModal = true;
        showDetailsModal = false;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void ViewBuildingDetails(Building building)
    {
        selectedBuilding = building;
        showDetailsModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showBuildingModal = false;
        buildingModel = new Building();
        isProcessing = false;
        isEditMode = false;
        StateHasChanged();
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedBuilding = null;
        StateHasChanged();
    }

    private void ManageRooms(Building building)
    {
        // Navigate to room management for this building
        CloseModal();
        CloseDetailsModal();
        ShowStatusMessage($"Redirecting to room management for {building.Name}...", "success");
        // In a real implementation, you'd navigate to /admin/rooms?buildingId={building.Id}
    }

    private async Task SaveBuilding()
    {
        if (string.IsNullOrWhiteSpace(buildingModel.Name))
        {
            ShowStatusMessage("Building name is required.", "error");
            return;
        }

        if (string.IsNullOrWhiteSpace(buildingModel.Address))
        {
            ShowStatusMessage("Building address is required.", "error");
            return;
        }

        isProcessing = true;
        StateHasChanged();

        try
        {
            if (isEditMode)
            {
                await BuildingService.UpdateBuildingAsync(buildingModel);
                ShowStatusMessage($"Facility '{buildingModel.Name}' updated successfully!", "success");
            }
            else
            {
                await BuildingService.CreateBuildingAsync(buildingModel);
                ShowStatusMessage($"Facility '{buildingModel.Name}' created successfully!", "success");
            }

            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error saving facility: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteBuilding(Building building)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the facility '{building.Name}'? This will also delete all rooms in this facility. This action cannot be undone."))
        {
            try
            {
                var result = await BuildingService.DeleteBuildingAsync(building.Id);
                if (result)
                {
                    ShowStatusMessage($"Facility '{building.Name}' deleted successfully!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to delete facility. Facility not found.", "error");
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error deleting facility: {ex.Message}", "error");
            }
        }
    }

    private async Task ExportToPdf()
    {
        try
        {
            isProcessing = true;
            StateHasChanged();

            // Simulate PDF export
            await Task.Delay(2000);
            ShowStatusMessage("PDF export completed! Download should start automatically.", "success");
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error exporting PDF: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        if (type == "success")
        {
            Task.Delay(5000).ContinueWith(task =>
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }
}

