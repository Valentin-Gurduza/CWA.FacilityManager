@page "/admin/rooms"
@using Microsoft.AspNetCore.Authorization
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Application.Interfaces
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode InteractiveServer
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Room Management</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-door-open me-2 text-primary"></i>Room Management
        </h1>
        <button class="btn btn-primary" @onclick="ShowAddRoomModal">
            <i class="fas fa-plus me-2"></i>Add New Room
        </button>
    </div>

    <!-- Status Messages -->
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show">
            <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle") me-2"></i>
            @statusMessage
            <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
        </div>
    }

    <!-- Room Statistics -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-center bg-light">
                <div class="card-body py-3">
                    <i class="fas fa-door-open text-primary" style="font-size: 2rem;"></i>
                    <h4 class="mt-2 mb-0">@(rooms?.Count() ?? 0)</h4>
                    <small class="text-muted">Total Rooms</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center bg-light">
                <div class="card-body py-3">
                    <i class="fas fa-check-circle text-success" style="font-size: 2rem;"></i>
                    <h4 class="mt-2 mb-0">@(rooms?.Count(r => r.IsActive && r.IsAvailable) ?? 0)</h4>
                    <small class="text-muted">Available</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center bg-light">
                <div class="card-body py-3">
                    <i class="fas fa-tools text-warning" style="font-size: 2rem;"></i>
                    <h4 class="mt-2 mb-0">@(rooms?.Count(r => !r.IsActive) ?? 0)</h4>
                    <small class="text-muted">Inactive</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center bg-light">
                <div class="card-body py-3">
                    <i class="fas fa-users text-info" style="font-size: 2rem;"></i>
                    <h4 class="mt-2 mb-0">@(rooms?.Sum(r => r.Capacity) ?? 0)</h4>
                    <small class="text-muted">Total Capacity</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Search rooms..." @bind="searchTerm" @bind:after="ApplyFilters" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="buildingFilter" @bind:after="ApplyFilters">
                        <option value="">All Facilities</option>
                        @if (buildings != null)
                        {
                            @foreach (var building in buildings)
                            {
                                <option value="@building.Id">@building.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">
                        <i class="fas fa-undo me-1"></i>Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Rooms Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Rooms (@(filteredRooms?.Count() ?? 0))</h5>
        </div>
        <div class="card-body p-0">
            @if (filteredRooms == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border" role="status"></div>
                </div>
            }
            else if (!filteredRooms.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-door-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No rooms found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Room Name</th>
                                <th>Facility</th>
                                <th>Type</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th class="text-end" style="width: 140px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var room in filteredRooms)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-medium">@room.Name</div>
                                        @if (!string.IsNullOrEmpty(room.RoomNumber))
                                        {
                                            <small class="text-muted">Room @room.RoomNumber</small>
                                        }
                                    </td>
                                    <td>@room.Building?.Name</td>
                                    <td>
                                        <span class="badge @GetActivityBadgeClass(room.Activity)">@room.Activity</span>
                                    </td>
                                    <td><i class="fas fa-users me-1"></i>@room.Capacity</td>
                                    <td>
                                        <span class="badge @(room.IsActive ? "bg-success" : "bg-danger")">
                                            @(room.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowViewModal(room)" title="View">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => ShowEditModal(room)" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-outline-info btn-sm" @onclick="() => ShowActionsModal(room)" title="More">
                                                <i class="fas fa-ellipsis-v"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- View Room Modal -->
@if (showViewModal && selectedRoom != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-door-open me-2"></i>@selectedRoom.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm">
                        <tr><td class="fw-bold">Room Number:</td><td>@(selectedRoom.RoomNumber ?? "N/A")</td></tr>
                        <tr><td class="fw-bold">Facility:</td><td>@(selectedRoom.Building?.Name ?? "N/A")</td></tr>
                        <tr><td class="fw-bold">Capacity:</td><td>@selectedRoom.Capacity people</td></tr>
                        <tr><td class="fw-bold">Type:</td><td><span class="badge @GetActivityBadgeClass(selectedRoom.Activity)">@selectedRoom.Activity</span></td></tr>
                        <tr><td class="fw-bold">Status:</td><td><span class="badge @(selectedRoom.IsActive ? "bg-success" : "bg-danger")">@(selectedRoom.IsActive ? "Active" : "Inactive")</span></td></tr>
                        <tr><td class="fw-bold">Hourly Rate:</td><td>@(selectedRoom.HourlyRate?.ToString("C") ?? "Free")</td></tr>
                        @if (!string.IsNullOrEmpty(selectedRoom.Location))
                        {
                            <tr><td class="fw-bold">Location:</td><td>@selectedRoom.Location</td></tr>
                        }
                    </table>
                    @if (!string.IsNullOrEmpty(selectedRoom.Description))
                    {
                        <hr />
                        <h6>Description</h6>
                        <p class="mb-0">@selectedRoom.Description</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => ShowEditModal(selectedRoom)"><i class="fas fa-edit me-1"></i>Edit</button>
                    <button class="btn btn-secondary" @onclick="CloseModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Edit Room Modal -->
@if (showEditModal && editingRoom != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Room</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Room Name *</label>
                            <input type="text" class="form-control" @bind="editingRoom.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Room Number</label>
                            <input type="text" class="form-control" @bind="editingRoom.RoomNumber" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Facility *</label>
                            <select class="form-select" @bind="editingRoom.BuildingId">
                                <option value="0">Select...</option>
                                @if (buildings != null)
                                {
                                    @foreach (var b in buildings)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Capacity *</label>
                            <input type="number" class="form-control" @bind="editingRoom.Capacity" min="1" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Activity Type *</label>
                            <select class="form-select" @bind="editingRoom.Activity">
                                @foreach (var a in Enum.GetValues<ActivityType>())
                                {
                                    <option value="@a">@a</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hourly Rate</label>
                            <input type="number" class="form-control" @bind="editingRoom.HourlyRate" step="0.01" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="2" @bind="editingRoom.Description"></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="editRoomIsActive" @bind="editingRoom.IsActive" />
                                <label class="form-check-label" for="editRoomIsActive">Active</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="editRoomIsAvailable" @bind="editingRoom.IsAvailable" />
                                <label class="form-check-label" for="editRoomIsAvailable">Available</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveRoom" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Add Room Modal -->
@if (showAddModal && newRoom != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-plus me-2"></i>Add New Room</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Room Name *</label>
                            <input type="text" class="form-control" @bind="newRoom.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Room Number</label>
                            <input type="text" class="form-control" @bind="newRoom.RoomNumber" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Facility *</label>
                            <select class="form-select" @bind="newRoom.BuildingId">
                                <option value="0">Select...</option>
                                @if (buildings != null)
                                {
                                    @foreach (var b in buildings)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Capacity *</label>
                            <input type="number" class="form-control" @bind="newRoom.Capacity" min="1" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Activity Type *</label>
                            <select class="form-select" @bind="newRoom.Activity">
                                @foreach (var a in Enum.GetValues<ActivityType>())
                                {
                                    <option value="@a">@a</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hourly Rate</label>
                            <input type="number" class="form-control" @bind="newRoom.HourlyRate" step="0.01" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="2" @bind="newRoom.Description"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateRoom" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create Room
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Actions Modal -->
@if (showActionsModal && selectedRoom != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-door-open me-2"></i>@selectedRoom.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" @onclick="() => ShowViewModal(selectedRoom)">
                            <i class="fas fa-eye me-2"></i>View Details
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="() => ShowEditModal(selectedRoom)">
                            <i class="fas fa-edit me-2"></i>Edit Room
                        </button>
                        <hr />
                        <button class="btn @(selectedRoom.IsActive ? "btn-outline-warning" : "btn-outline-success")" @onclick="ToggleStatus">
                            <i class="fas @(selectedRoom.IsActive ? "fa-pause" : "fa-play") me-2"></i>
                            @(selectedRoom.IsActive ? "Deactivate" : "Activate")
                        </button>
                        <button class="btn btn-outline-danger" @onclick="DeleteRoom">
                            <i class="fas fa-trash me-2"></i>Delete Room
                        </button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<Room>? rooms;
    private IEnumerable<Room>? filteredRooms;
    private IEnumerable<Building>? buildings;
    
    private bool showViewModal, showEditModal, showAddModal, showActionsModal;
    private Room? selectedRoom;
    private Room? editingRoom;
    private Room? newRoom;
    
    private bool isSaving;
    private string statusMessage = "";
    private string statusMessageType = "success";
    
    private string searchTerm = "";
    private string buildingFilter = "";
    private string statusFilter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            rooms = await RoomService.GetAllRoomsAsync();
            buildings = await BuildingService.GetAllBuildingsAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            statusMessage = "Error loading data: " + ex.Message;
            statusMessageType = "danger";
        }
    }

    private void ApplyFilters()
    {
        if (rooms == null) { filteredRooms = null; return; }
        
        filteredRooms = rooms;
        
        if (!string.IsNullOrEmpty(searchTerm))
            filteredRooms = filteredRooms.Where(r => r.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        
        if (!string.IsNullOrEmpty(buildingFilter) && int.TryParse(buildingFilter, out int bId))
            filteredRooms = filteredRooms.Where(r => r.BuildingId == bId);
        
        if (statusFilter == "active")
            filteredRooms = filteredRooms.Where(r => r.IsActive);
        else if (statusFilter == "inactive")
            filteredRooms = filteredRooms.Where(r => !r.IsActive);
    }

    private void ResetFilters()
    {
        searchTerm = "";
        buildingFilter = "";
        statusFilter = "";
        ApplyFilters();
    }

    private void CloseModals()
    {
        showViewModal = showEditModal = showAddModal = showActionsModal = false;
        selectedRoom = editingRoom = null;
    }

    private void ShowViewModal(Room room)
    {
        CloseModals();
        selectedRoom = room;
        showViewModal = true;
    }

    private void ShowEditModal(Room room)
    {
        CloseModals();
        editingRoom = new Room
        {
            Id = room.Id,
            Name = room.Name,
            RoomNumber = room.RoomNumber,
            BuildingId = room.BuildingId,
            Capacity = room.Capacity,
            Activity = room.Activity,
            Description = room.Description,
            HourlyRate = room.HourlyRate,
            Location = room.Location,
            IsActive = room.IsActive,
            IsAvailable = room.IsAvailable
        };
        showEditModal = true;
    }

    private void ShowAddRoomModal()
    {
        CloseModals();
        newRoom = new Room { Name = "", Capacity = 10, Activity = ActivityType.Meeting, IsActive = true, IsAvailable = true };
        showAddModal = true;
    }

    private void ShowActionsModal(Room room)
    {
        CloseModals();
        selectedRoom = room;
        showActionsModal = true;
    }

    private async Task SaveRoom()
    {
        if (editingRoom == null) return;
        isSaving = true;
        try
        {
            await RoomService.UpdateRoomAsync(editingRoom);
            statusMessage = "Room updated successfully.";
            statusMessageType = "success";
            CloseModals();
            await LoadData();
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
            statusMessageType = "danger";
        }
        isSaving = false;
    }

    private async Task CreateRoom()
    {
        if (newRoom == null || newRoom.BuildingId == 0)
        {
            statusMessage = "Please select a facility.";
            statusMessageType = "danger";
            return;
        }
        isSaving = true;
        try
        {
            await RoomService.CreateRoomAsync(newRoom);
            statusMessage = "Room created successfully.";
            statusMessageType = "success";
            CloseModals();
            await LoadData();
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
            statusMessageType = "danger";
        }
        isSaving = false;
    }

    private async Task ToggleStatus()
    {
        if (selectedRoom == null) return;
        try
        {
            selectedRoom.IsActive = !selectedRoom.IsActive;
            await RoomService.UpdateRoomAsync(selectedRoom);
            statusMessage = selectedRoom.IsActive ? "Room activated." : "Room deactivated.";
            statusMessageType = "success";
            CloseModals();
            await LoadData();
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
            statusMessageType = "danger";
        }
    }

    private async Task DeleteRoom()
    {
        if (selectedRoom == null) return;
        if (await JS.InvokeAsync<bool>("confirm", $"Delete '{selectedRoom.Name}'?"))
        {
            try
            {
                await RoomService.DeleteRoomAsync(selectedRoom.Id);
                statusMessage = "Room deleted.";
                statusMessageType = "success";
                CloseModals();
                await LoadData();
            }
            catch (Exception ex)
            {
                statusMessage = "Error: " + ex.Message;
                statusMessageType = "danger";
            }
        }
    }

    private void ClearStatusMessage() => statusMessage = "";

    private string GetActivityBadgeClass(ActivityType activity) => activity switch
    {
        ActivityType.Course => "bg-success",
        ActivityType.Meeting => "bg-primary",
        ActivityType.Training => "bg-warning",
        _ => "bg-secondary"
    };
}
