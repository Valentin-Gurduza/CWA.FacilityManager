    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        if (type == "success")
        {
            Task.Delay(4000).ContinueWith(task =>
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetEventTypeIcon(EventType type)
    {
        return type switch
        {
            EventType.Meeting => "fa-handshake",
            EventType.Course => "fa-graduation-cap",
            EventType.Conference => "fa-microphone",
            EventType.Training => "fa-dumbbell",
            EventType.Workshop => "fa-tools",
            _ => "fa-calendar"
        };
    }

    private string GetEventStatusColor(Event eventItem)
    {
        if (IsEventCompleted(eventItem)) return "text-secondary";
        if (IsEventActive(eventItem)) return "text-primary";
        if (eventItem.StartDateTime > DateTime.Now) return "text-success";
        return "text-muted";
    }

    private string GetEventStatusText(Event eventItem)
    {
        if (IsEventCompleted(eventItem)) return "Completed";
        if (IsEventActive(eventItem)) return "Active";
        if (eventItem.StartDateTime > DateTime.Now) return "Upcoming";
        return "Past";
    }

    private bool IsEventActive(Event eventItem)
    {
        var now = DateTime.Now;
        return eventItem.StartDateTime <= now && eventItem.EndDateTime > now;
    }

    private bool IsEventCompleted(Event eventItem)
    {
        return eventItem.EndDateTime < DateTime.Now;
    }
}

