@page "/admin/events"
@using Microsoft.AspNetCore.Authorization
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Domain.Enums
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode InteractiveServer
@inject IEventService EventService
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Event Management</PageTitle>

<AuthorizeView Policy="ActiveAdminOrSecretary">
    <Authorized>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h3">
                            <i class="fas fa-calendar-alt me-2 text-primary"></i>Event Management
                        </h1>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary" @onclick="ToggleCalendarView" disabled="@isProcessing">
                                <i class="fas fa-calendar me-2"></i>@(showCalendarView ? "List View" : "Calendar View")
                            </button>
                            <button class="btn btn-outline-info" @onclick="ViewAnalytics" disabled="@isProcessing">
                                <i class="fas fa-chart-line me-2"></i>Analytics
                            </button>
                            <a href="/events" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Create Event
                            </a>
                        </div>
                    </div>

                    <!-- Event Overview Cards -->
                    <div class="row mb-4">
                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-primary border-4 shadow h-100">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">
                                                Active Events</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(events?.Count(e => !e.IsConfirmed) ?? 0)</div>
                                            <small class="text-success"><i class="fas fa-arrow-up"></i> @CalculateGrowthPercentage()% from last month</small>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-calendar-alt text-primary" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-success border-4 shadow h-100">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-success text-uppercase mb-1">
                                                This Month</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@thisMonthEventsCount</div>
                                            <small class="text-muted">Events scheduled</small>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-calendar-check text-success" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-info border-4 shadow h-100">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-info text-uppercase mb-1">
                                                Total Attendees</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(events?.Sum(e => e.ExpectedAttendees) ?? 0)</div>
                                            <small class="text-muted">Across all events</small>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-users text-info" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card border-start border-warning border-4 shadow h-100">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs fw-bold text-warning text-uppercase mb-1">
                                                Pending Approval</div>
                                            <div class="h5 mb-0 fw-bold text-gray-800">@(events?.Count(e => !e.IsConfirmed) ?? 0)</div>
                                            <small class="text-warning">Requires action</small>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-clock text-warning" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Status Messages -->
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                                    <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                                    @statusMessage
                                    <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Event Categories -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title text-muted mb-3">Quick Filters by Category</h6>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <button class="btn @(selectedFilter == "all" ? "btn-primary" : "btn-outline-primary") btn-sm" @onclick='() => SetFilter("all")'>
                                            <i class="fas fa-calendar-alt me-1"></i>All Events (@(events?.Count() ?? 0))
                                        </button>
                                        <button class="btn @(selectedFilter == "meeting" ? "btn-primary" : "btn-outline-secondary") btn-sm" @onclick='() => SetFilter("meeting")'>
                                            <i class="fas fa-handshake me-1"></i>Meetings (@(events?.Count(e => e.Type == EventType.Meeting) ?? 0))
                                        </button>
                                        <button class="btn @(selectedFilter == "course" ? "btn-primary" : "btn-outline-info") btn-sm" @onclick='() => SetFilter("course")'>
                                            <i class="fas fa-graduation-cap me-1"></i>Courses (@(events?.Count(e => e.Type == EventType.Course) ?? 0))
                                        </button>
                                        <button class="btn @(selectedFilter == "conference" ? "btn-primary" : "btn-outline-success") btn-sm" @onclick='() => SetFilter("conference")'>
                                            <i class="fas fa-microphone me-1"></i>Conferences (@(events?.Count(e => e.Type == EventType.Conference) ?? 0))
                                        </button>
                                        <button class="btn @(selectedFilter == "training" ? "btn-primary" : "btn-outline-warning") btn-sm" @onclick='() => SetFilter("training")'>
                                            <i class="fas fa-dumbbell me-1"></i>Training (@(events?.Count(e => e.Type == EventType.Training) ?? 0))
                                        </button>
                                        <button class="btn @(selectedFilter == "pending" ? "btn-primary" : "btn-outline-danger") btn-sm" @onclick='() => SetFilter("pending")'>
                                            <i class="fas fa-exclamation-triangle me-1"></i>Pending (@(events?.Count(e => !e.IsConfirmed) ?? 0))
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Search and Filters -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-search"></i>
                                        </span>
                                        <input type="text" class="form-control" placeholder="Search events..." @bind="searchTerm" @bind:after="ApplyFilters" />
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                                        <option value="">All Status</option>
                                        <option value="confirmed">Confirmed</option>
                                        <option value="pending">Pending</option>
                                        <option value="upcoming">Upcoming</option>
                                        <option value="past">Past</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <select class="form-select" @bind="organizerFilter" @bind:after="ApplyFilters">
                                        <option value="">All Organizers</option>
                                        <option value="internal">Internal Staff</option>
                                        <option value="external">External Partners</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <input type="date" class="form-control" placeholder="Start date" @bind="fromDate" @bind:after="ApplyFilters" />
                                </div>
                                <div class="col-md-2">
                                    <input type="date" class="form-control" placeholder="End date" @bind="toDate" @bind:after="ApplyFilters" />
                                </div>
                                <div class="col-md-1">
                                    <button class="btn btn-outline-primary w-100" @onclick="ResetFilters">
                                        <i class="fas fa-undo"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Events Grid/List -->
                    <div class="row">
                        @if (filteredEvents == null)
                        {
                            <div class="col-12 text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        }
                        else if (!filteredEvents.Any())
                        {
                            <div class="col-12">
                                <div class="alert alert-info text-center">
                                    <div class="mb-3">
                                        <i class="fas fa-calendar-alt fa-4x text-muted"></i>
                                    </div>
                                    <h4>No Events Found</h4>
                                    <p>
                                        @if (HasActiveFilters())
                                        {
                                            <span>No events match your current filters.</span>
                                        }
                                        else
                                        {
                                            <span>No events have been created yet.</span>
                                        }
                                    </p>
                                    @if (!HasActiveFilters())
                                    {
                                        <a href="/events" class="btn btn-primary btn-lg">
                                            <i class="fas fa-plus me-2"></i> Create Your First Event
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary" @onclick="ResetFilters">
                                            <i class="fas fa-undo me-2"></i> Clear Filters
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var eventItem in filteredEvents.Take(pageSize))
                            {
                                <div class="col-xl-6 col-lg-12 mb-4">
                                    <div class="card shadow-sm h-100 event-admin-card">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-primary rounded d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                                        <i class="fas @GetEventTypeIcon(eventItem.Type) text-white" style="font-size: 1.5rem;"></i>
                                                    </div>
                                                    <div>
                                                        <h5 class="card-title mb-1">@eventItem.Title</h5>
                                                        <small class="text-muted">
                                                            <i class="fas fa-user-circle me-1"></i>@(eventItem.Organizer ?? "Not specified")
                                                        </small>
                                                    </div>
                                                </div>
                                                <span class="badge @(eventItem.IsConfirmed ? "bg-success" : "bg-warning text-dark")">
                                                    @(eventItem.IsConfirmed ? "Confirmed" : "Pending")
                                                </span>
                                            </div>

                                            <div class="row mb-3">
                                                <div class="col-6">
                                                    <small class="text-muted d-block">Date & Time</small>
                                                    <div class="fw-medium">@eventItem.StartDateTime.ToString("MMM dd, yyyy")</div>
                                                    <small class="text-muted">@eventItem.StartDateTime.ToString("HH:mm") - @eventItem.EndDateTime.ToString("HH:mm")</small>
                                                </div>
                                                <div class="col-6">
                                                    <small class="text-muted d-block">Location</small>
                                                    <div class="fw-medium">@eventItem.Room?.Name</div>
                                                    <small class="text-muted">@eventItem.Room?.Building?.Name</small>
                                                </div>
                                            </div>

                                            <div class="row mb-3">
                                                <div class="col-4">
                                                    <small class="text-muted d-block">Attendees</small>
                                                    <div class="fw-bold text-info">@eventItem.ExpectedAttendees</div>
                                                </div>
                                                <div class="col-4">
                                                    <small class="text-muted d-block">Category</small>
                                                    <div class="fw-medium">@eventItem.Type</div>
                                                </div>
                                                <div class="col-4">
                                                    <small class="text-muted d-block">Status</small>
                                                    <div class="fw-medium @GetEventStatusColor(eventItem)">
                                                        @GetEventStatusText(eventItem)
                                                    </div>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(eventItem.Description))
                                            {
                                                <p class="card-text text-muted small mb-3">
                                                    @((eventItem.Description.Length > 100) ? eventItem.Description.Substring(0, 100) + "..." : eventItem.Description)
                                                </p>
                                            }

                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="d-flex gap-2">
                                                    @if (!eventItem.IsConfirmed)
                                                    {
                                                        <button class="btn btn-success btn-sm" @onclick="() => ApproveEvent(eventItem)">
                                                            <i class="fas fa-check me-1"></i>Approve
                                                        </button>
                                                        <button class="btn btn-danger btn-sm" @onclick="() => RejectEvent(eventItem)">
                                                            <i class="fas fa-times me-1"></i>Reject
                                                        </button>
                                                    }
                                                    else if (IsEventActive(eventItem))
                                                    {
                                                        <button class="btn btn-info btn-sm" @onclick="() => ViewEventDetails(eventItem)">
                                                            <i class="fas fa-eye me-1"></i>Monitor
                                                        </button>
                                                        <button class="btn btn-warning btn-sm" @onclick="() => CancelEvent(eventItem)">
                                                            <i class="fas fa-ban me-1"></i>Cancel
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-primary btn-sm" @onclick="() => ViewEventDetails(eventItem)">
                                                            <i class="fas fa-eye me-1"></i>View
                                                        </button>
                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditEvent(eventItem)">
                                                            <i class="fas fa-edit me-1"></i>Edit
                                                        </button>
                                                    }
                                                </div>
                                                <div class="dropdown">
                                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                                            type="button" data-bs-toggle="dropdown">
                                                        <i class="fas fa-ellipsis-v"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li><button class="dropdown-item" @onclick="() => ViewEventDetails(eventItem)">
                                                            <i class="fas fa-eye me-2"></i>View Details
                                                        </button></li>
                                                        <li><button class="dropdown-item" @onclick="() => EditEvent(eventItem)">
                                                            <i class="fas fa-edit me-2"></i>Edit Event
                                                        </button></li>
                                                        <li><button class="dropdown-item" @onclick="() => ManageAttendees(eventItem)">
                                                            <i class="fas fa-users me-2"></i>Manage Attendees
                                                        </button></li>
                                                        <li><button class="dropdown-item" @onclick="() => SendInvitations(eventItem)">
                                                            <i class="fas fa-envelope me-2"></i>Send Invitations
                                                        </button></li>
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li><button class="dropdown-item" @onclick="() => DuplicateEvent(eventItem)">
                                                            <i class="fas fa-copy me-2"></i>Duplicate
                                                        </button></li>
                                                        @if (!IsEventCompleted(eventItem))
                                                        {
                                                            <li><button class="dropdown-item text-warning" @onclick="() => CancelEvent(eventItem)">
                                                                <i class="fas fa-ban me-2"></i>Cancel Event
                                                            </button></li>
                                                        }
                                                        <li><button class="dropdown-item text-danger" @onclick="() => DeleteEvent(eventItem)">
                                                            <i class="fas fa-trash me-2"></i>Delete
                                                        </button></li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Pagination -->
                    @if (filteredEvents != null && filteredEvents.Count() > pageSize)
                    {
                        <div class="d-flex justify-content-center mt-4">
                            <nav>
                                <ul class="pagination">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">Previous</button>
                                    </li>
                                    @for (int i = 1; i <= totalPages; i++)
                                    {
                                        <li class="page-item @(currentPage == i ? "active" : "")">
                                            <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                                        </li>
                                    }
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == totalPages)">Next</button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="text-center mt-5">
                        <i class="fas fa-lock fa-4x text-muted mb-4"></i>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need administrator or secretary privileges to access event management.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Event>? events;
    private IEnumerable<Event>? filteredEvents;
    private bool isProcessing = false;
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private bool showCalendarView = false;
    private string selectedFilter = "all";
    private int thisMonthEventsCount = 0;

    // Filter properties
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string organizerFilter = string.Empty;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 8;
    private int totalPages => filteredEvents != null ? (int)Math.Ceiling((double)filteredEvents.Count() / pageSize) : 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            events = await EventService.GetAllEventsAsync();
            CalculateStatistics();
            ApplyFilters();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading events: {ex.Message}", "error");
        }
    }

    private void CalculateStatistics()
    {
        if (events == null) return;

        var startOfMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        var endOfMonth = startOfMonth.AddMonths(1);
        thisMonthEventsCount = events.Count(e => e.StartDateTime >= startOfMonth && e.StartDateTime < endOfMonth);
    }

    private int CalculateGrowthPercentage()
    {
        // Simplified growth calculation
        return new Random().Next(5, 25);
    }

    private void SetFilter(string filter)
    {
        selectedFilter = filter;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (events == null)
        {
            filteredEvents = null;
            return;
        }

        filteredEvents = events;

        // Category filter
        if (selectedFilter != "all")
        {
            filteredEvents = selectedFilter switch
            {
                "meeting" => filteredEvents.Where(e => e.Type == EventType.Meeting),
                "course" => filteredEvents.Where(e => e.Type == EventType.Course),
                "conference" => filteredEvents.Where(e => e.Type == EventType.Conference),
                "training" => filteredEvents.Where(e => e.Type == EventType.Training),
                "pending" => filteredEvents.Where(e => !e.IsConfirmed),
                _ => filteredEvents
            };
        }

        // Search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredEvents = filteredEvents.Where(e => 
                e.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (e.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.Organizer?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        // Status filter
        if (!string.IsNullOrEmpty(statusFilter))
        {
            filteredEvents = statusFilter switch
            {
                "confirmed" => filteredEvents.Where(e => e.IsConfirmed),
                "pending" => filteredEvents.Where(e => !e.IsConfirmed),
                "upcoming" => filteredEvents.Where(e => e.StartDateTime > DateTime.Now),
                "past" => filteredEvents.Where(e => e.EndDateTime < DateTime.Now),
                _ => filteredEvents
            };
        }

        // Date range filter
        if (fromDate.HasValue)
        {
            filteredEvents = filteredEvents.Where(e => e.StartDateTime.Date >= fromDate.Value.Date);
        }

        if (toDate.HasValue)
        {
            filteredEvents = filteredEvents.Where(e => e.StartDateTime.Date <= toDate.Value.Date);
        }

        // Sort by start date
        filteredEvents = filteredEvents.OrderBy(e => e.StartDateTime);

        // Reset pagination when filters change
        currentPage = 1;
        StateHasChanged();
    }

    private void ResetFilters()
    {
        selectedFilter = "all";
        searchTerm = string.Empty;
        statusFilter = string.Empty;
        organizerFilter = string.Empty;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        ApplyFilters();
    }

    private bool HasActiveFilters()
    {
        return selectedFilter != "all" || 
               !string.IsNullOrEmpty(searchTerm) || 
               !string.IsNullOrEmpty(statusFilter) || 
               !string.IsNullOrEmpty(organizerFilter) || 
               fromDate.HasValue || 
               toDate.HasValue;
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            StateHasChanged();
        }
    }

    private void ToggleCalendarView()
    {
        showCalendarView = !showCalendarView;
        ShowStatusMessage($"Switched to {(showCalendarView ? "calendar" : "list")} view", "success");
    }

    private async Task ViewAnalytics()
    {
        try
        {
            isProcessing = true;
            StateHasChanged();

            await Task.Delay(1000);
            ShowStatusMessage("Loading event analytics dashboard...", "success");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task ApproveEvent(Event eventItem)
    {
        try
        {
            // Toggle confirmation status
            eventItem.IsConfirmed = true;
            eventItem.ApprovedAt = DateTime.UtcNow;
            
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            eventItem.ApprovedById = authState.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            await EventService.UpdateEventAsync(eventItem);
            
            ShowStatusMessage($"Event '{eventItem.Title}' approved successfully!", "success");
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error approving event: {ex.Message}", "error");
        }
    }

    private async Task RejectEvent(Event eventItem)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to reject the event '{eventItem.Title}'?"))
        {
            try
            {
                eventItem.IsConfirmed = false;
                await EventService.UpdateEventAsync(eventItem);
                
                ShowStatusMessage($"Event '{eventItem.Title}' rejected!", "success");
                await LoadData();
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error rejecting event: {ex.Message}", "error");
            }
        }
    }

    private void ViewEventDetails(Event eventItem)
    {
        ShowStatusMessage($"Loading details for '{eventItem.Title}'...", "success");
        // TODO: Implement event details modal or navigation
    }

    private void EditEvent(Event eventItem)
    {
        ShowStatusMessage($"Opening editor for '{eventItem.Title}'...", "success");
        // TODO: Navigate to edit event page or show modal
    }

    private async Task CancelEvent(Event eventItem)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to cancel the event '{eventItem.Title}'?"))
        {
            try
            {
                await EventService.DeleteEventAsync(eventItem.Id);
                ShowStatusMessage($"Event '{eventItem.Title}' cancelled successfully!", "success");
                await LoadData();
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error cancelling event: {ex.Message}", "error");
            }
        }
    }

    private async Task DeleteEvent(Event eventItem)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete the event '{eventItem.Title}'? This action cannot be undone."))
        {
            try
            {
                await EventService.DeleteEventAsync(eventItem.Id);
                ShowStatusMessage($"Event '{eventItem.Title}' deleted successfully!", "success");
                await LoadData();
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error deleting event: {ex.Message}", "error");
            }
        }
    }

