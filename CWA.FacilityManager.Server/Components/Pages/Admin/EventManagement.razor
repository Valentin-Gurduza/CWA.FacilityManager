@page "/admin/events"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Event Management</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">
                    <i class="bi bi-calendar-event-fill me-2 text-primary"></i>Event Management
                </h1>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary">
                        <i class="bi bi-calendar3 me-2"></i>Event Calendar
                    </button>
                    <button class="btn btn-outline-info">
                        <i class="bi bi-graph-up me-2"></i>Analytics
                    </button>
                    <button class="btn btn-primary">
                        <i class="bi bi-plus-circle-fill me-2"></i>Create Event
                    </button>
                </div>
            </div>

            <!-- Event Overview Cards -->
            <div class="row mb-4">
                <div class="col-xl-3 col-md-6">
                    <div class="card border-left-primary shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Active Events</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">47</div>
                                    <small class="text-success"><i class="bi bi-arrow-up"></i> 12% from last month</small>
                                </div>
                                <div class="col-auto">
                                    <i class="bi bi-calendar-event text-primary" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card border-left-success shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                        This Month</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">156</div>
                                    <small class="text-muted">Events scheduled</small>
                                </div>
                                <div class="col-auto">
                                    <i class="bi bi-calendar-month text-success" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card border-left-info shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                        Total Attendees</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">2,847</div>
                                    <small class="text-muted">Across all events</small>
                                </div>
                                <div class="col-auto">
                                    <i class="bi bi-people text-info" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card border-left-warning shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                        Pending Approval</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">8</div>
                                    <small class="text-warning">Requires action</small>
                                </div>
                                <div class="col-auto">
                                    <i class="bi bi-clock-history text-warning" style="font-size: 2.5rem; opacity: 0.3;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Event Categories -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title text-muted mb-3">Quick Filters by Category</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-outline-primary btn-sm active">
                                    <i class="bi bi-calendar-event me-1"></i>All Events (47)
                                </button>
                                <button class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-briefcase me-1"></i>Corporate (18)
                                </button>
                                <button class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-mortarboard me-1"></i>Training (12)
                                </button>
                                <button class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-people me-1"></i>Team Building (8)
                                </button>
                                <button class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-graph-up me-1"></i>Presentations (9)
                                </button>
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Pending (8)
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Search and Filters -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" class="form-control" placeholder="Search events..." />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select">
                                <option value="">All Status</option>
                                <option value="draft">Draft</option>
                                <option value="pending">Pending Approval</option>
                                <option value="approved">Approved</option>
                                <option value="active">Active</option>
                                <option value="completed">Completed</option>
                                <option value="cancelled">Cancelled</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select">
                                <option value="">All Organizers</option>
                                <option value="internal">Internal Staff</option>
                                <option value="external">External Partners</option>
                                <option value="clients">Clients</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input type="date" class="form-control" placeholder="Start date" />
                        </div>
                        <div class="col-md-2">
                            <input type="date" class="form-control" placeholder="End date" />
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-outline-primary w-100">
                                <i class="bi bi-funnel-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Events Grid/List -->
            <div class="row">
                @for (int i = 1; i <= 8; i++)
                {
                    var eventStatuses = new[] { "approved", "pending", "active", "completed", "draft" };
                    var statusClasses = new[] { "success", "warning", "primary", "secondary", "light" };
                    var statusTexts = new[] { "Approved", "Pending", "Active", "Completed", "Draft" };
                    var statusIndex = (i - 1) % 5;
                    var eventDate = DateTime.Now.AddDays(i * 3 - 10);

                    <div class="col-xl-6 col-lg-12 mb-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary rounded d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="bi bi-calendar-event text-white" style="font-size: 1.5rem;"></i>
                                        </div>
                                        <div>
                                            <h5 class="card-title mb-1">@GetEventTitle(i)</h5>
                                            <small class="text-muted">
                                                <i class="bi bi-person-circle me-1"></i>@GetOrganizerName(i)
                                            </small>
                                        </div>
                                    </div>
                                    <span class="badge bg-@statusClasses[statusIndex]">
                                        @statusTexts[statusIndex]
                                    </span>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-6">
                                        <small class="text-muted d-block">Date & Time</small>
                                        <div class="fw-medium">@eventDate.ToString("MMM dd, yyyy")</div>
                                        <small class="text-muted">@(9 + i % 4):00 - @(12 + i % 4):00</small>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted d-block">Location</small>
                                        <div class="fw-medium">Conference Room @(i % 5 + 1)</div>
                                        <small class="text-muted">Facility @(i % 3 + 1)</small>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-4">
                                        <small class="text-muted d-block">Attendees</small>
                                        <div class="fw-bold text-info">@(i * 15 + 25)</div>
                                    </div>
                                    <div class="col-4">
                                        <small class="text-muted d-block">Category</small>
                                        <div class="fw-medium">@GetEventCategory(i)</div>
                                    </div>
                                    <div class="col-4">
                                        <small class="text-muted d-block">Priority</small>
                                        <div class="fw-medium text-@(i % 3 == 0 ? "danger" : i % 2 == 0 ? "warning" : "success")">
                                            @(i % 3 == 0 ? "High" : i % 2 == 0 ? "Medium" : "Low")
                                        </div>
                                    </div>
                                </div>

                                <p class="card-text text-muted small mb-3">
                                    @GetEventDescription(i)
                                </p>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex gap-2">
                                        @if (statusTexts[statusIndex] == "Pending")
                                        {
                                            <button class="btn btn-success btn-sm">
                                                <i class="bi bi-check-lg me-1"></i>Approve
                                            </button>
                                            <button class="btn btn-danger btn-sm">
                                                <i class="bi bi-x-lg me-1"></i>Reject
                                            </button>
                                        }
                                        else if (statusTexts[statusIndex] == "Active")
                                        {
                                            <button class="btn btn-info btn-sm">
                                                <i class="bi bi-eye-fill me-1"></i>Monitor
                                            </button>
                                            <button class="btn btn-warning btn-sm">
                                                <i class="bi bi-pause-fill me-1"></i>Pause
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-primary btn-sm">
                                                <i class="bi bi-eye-fill me-1"></i>View
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-pencil-fill me-1"></i>Edit
                                            </button>
                                        }
                                    </div>
                                    <div class="dropdown">
                                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                                type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="#">
                                                <i class="bi bi-eye-fill me-2"></i>View Details
                                            </a></li>
                                            <li><a class="dropdown-item" href="#">
                                                <i class="bi bi-pencil-fill me-2"></i>Edit Event
                                            </a></li>
                                            <li><a class="dropdown-item" href="#">
                                                <i class="bi bi-people-fill me-2"></i>Manage Attendees
                                            </a></li>
                                            <li><a class="dropdown-item" href="#">
                                                <i class="bi bi-envelope-fill me-2"></i>Send Invitations
                                            </a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" href="#">
                                                <i class="bi bi-files me-2"></i>Duplicate
                                            </a></li>
                                            @if (statusTexts[statusIndex] != "Completed" && statusTexts[statusIndex] != "Cancelled")
                                            {
                                                <li><a class="dropdown-item text-warning" href="#">
                                                    <i class="bi bi-x-circle me-2"></i>Cancel Event
                                                </a></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Load More Button -->
            <div class="text-center mt-4">
                <button class="btn btn-outline-primary">
                    <i class="bi bi-arrow-down-circle me-2"></i>Load More Events
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string GetEventTitle(int index)
    {
        var titles = new[] {
            "Annual Company Conference",
            "Product Development Workshop",
            "Customer Success Training",
            "Q4 Strategy Planning Session",
            "New Employee Onboarding",
            "Technical Innovation Summit",
            "Sales Team Quarterly Review",
            "Leadership Development Program",
            "Client Appreciation Event",
            "Digital Transformation Seminar"
        };
        return titles[(index - 1) % titles.Length];
    }

    private string GetEventCategory(int index)
    {
        var categories = new[] { "Corporate", "Training", "Workshop", "Conference", "Meeting", "Seminar" };
        return categories[(index - 1) % categories.Length];
    }

    private string GetEventDescription(int index)
    {
        var descriptions = new[] {
            "A comprehensive session covering strategic objectives and operational excellence initiatives.",
            "Interactive workshop focused on skill development and best practices implementation.",
            "Essential training program designed to enhance team capabilities and performance.",
            "Strategic planning session to align goals and establish quarterly objectives.",
            "Comprehensive orientation program for new team members and stakeholders.",
            "Innovation-focused summit exploring emerging technologies and market trends."
        };
        return descriptions[(index - 1) % descriptions.Length];
    }

    private string GetOrganizerName(int index)
    {
        var names = new[] {
            "Sarah Johnson", "Michael Chen", "Emily Rodriguez", "David Thompson", 
            "Jennifer Williams", "Robert Kim", "Lisa Anderson", "James Miller"
        };
        return names[(index - 1) % names.Length];
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }
}