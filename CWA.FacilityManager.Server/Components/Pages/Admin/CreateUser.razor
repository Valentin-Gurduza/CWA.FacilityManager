@page "/admin/users/create"
@using CWA.FacilityManager.Application.DTOs.UserManagement
@using CWA.FacilityManager.Application.Interfaces.UserManagement
@using Microsoft.AspNetCore.Authorization
@inject IUserManagementService UserManagementService
@inject IRoleManagementService RoleManagementService
@inject NavigationManager Navigation
@attribute [Authorize(Policy = "ActiveAdminOrSecretary")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Create New User</PageTitle>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0">
                            <i class="bi bi-person-plus me-2"></i>Create New User
                        </h4>
                        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                            <i class="bi bi-arrow-left me-1"></i>Back to Users
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <EditForm Model="createUserDto" OnValidSubmit="CreateNewUser">
                        <DataAnnotationsValidator />

                        <!-- Basic Information -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="firstName" class="form-label">First Name</label>
                                <InputText id="firstName" class="form-control" @bind-Value="createUserDto.FirstName" placeholder="Enter first name" />
                                <ValidationMessage For="() => createUserDto.FirstName" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label for="lastName" class="form-label">Last Name</label>
                                <InputText id="lastName" class="form-control" @bind-Value="createUserDto.LastName" placeholder="Enter last name" />
                                <ValidationMessage For="() => createUserDto.LastName" class="text-danger" />
                            </div>
                        </div>

                        <!-- Account Information -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="userName" class="form-label">Username <span class="text-danger">*</span></label>
                                <InputText id="userName" class="form-control" @bind-Value="createUserDto.UserName" placeholder="Enter username" required />
                                <ValidationMessage For="() => createUserDto.UserName" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                                <InputText id="email" type="email" class="form-control" @bind-Value="createUserDto.Email" placeholder="Enter email address" required />
                                <ValidationMessage For="() => createUserDto.Email" class="text-danger" />
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="password" class="form-label">Password <span class="text-danger">*</span></label>
                                <InputText id="password" type="password" class="form-control" @bind-Value="createUserDto.Password" placeholder="Enter password" required />
                                <ValidationMessage For="() => createUserDto.Password" class="text-danger" />
                                <div class="form-text">Minimum 8 characters with uppercase, lowercase, and numbers.</div>
                            </div>
                            <div class="col-md-6">
                                <label for="phoneNumber" class="form-label">Phone Number</label>
                                <InputText id="phoneNumber" class="form-control" @bind-Value="createUserDto.PhoneNumber" placeholder="Enter phone number" />
                                <ValidationMessage For="() => createUserDto.PhoneNumber" class="text-danger" />
                            </div>
                        </div>

                        <!-- Organization Information -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="department" class="form-label">Department</label>
                                <InputText id="department" class="form-control" @bind-Value="createUserDto.Department" placeholder="Enter department" />
                                <ValidationMessage For="() => createUserDto.Department" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label for="jobTitle" class="form-label">Job Title</label>
                                <InputText id="jobTitle" class="form-control" @bind-Value="createUserDto.JobTitle" placeholder="Enter job title" />
                                <ValidationMessage For="() => createUserDto.JobTitle" class="text-danger" />
                            </div>
                        </div>

                        <!-- Role Assignment -->
                        <div class="mb-3">
                            <label class="form-label">Assign Roles</label>
                            @if (availableRoles.Any())
                            {
                                <div class="row">
                                    @foreach (var role in availableRoles)
                                    {
                                        <div class="col-md-4 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" 
                                                       id="role_@role.Id" 
                                                       checked="@createUserDto.RoleIds.Contains(role.Id)"
                                                       @onchange="(e) => ToggleRole(role.Id, (bool)e.Value!)" />
                                                <label class="form-check-label" for="role_@role.Id">
                                                    @role.Name
                                                    @if (!string.IsNullOrEmpty(role.Description))
                                                    {
                                                        <small class="text-muted d-block">@role.Description</small>
                                                    }
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle me-2"></i>No roles available. Please create roles first.
                                </div>
                            }
                        </div>

                        <!-- Email Confirmation Option -->
                        <div class="mb-3">
                            <div class="form-check">
                                <InputCheckbox id="sendEmailConfirmation" class="form-check-input" @bind-Value="createUserDto.SendEmailConfirmation" />
                                <label class="form-check-label" for="sendEmailConfirmation">
                                    Send email confirmation link
                                </label>
                                <div class="form-text">If unchecked, the user's email will be automatically confirmed.</div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Creating...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle me-1"></i>
                                    <span>Create User</span>
                                }
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@isCreating">
                                Cancel
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Error Alert -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show" role="alert">
            <div class="toast-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" @onclick="() => errorMessage = string.Empty"></button>
            </div>
            <div class="toast-body">
                @errorMessage
            </div>
        </div>
    </div>
}

@code {
    private CreateUserDto createUserDto = new();
    private List<RoleDto> availableRoles = new();
    private bool isCreating = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableRoles = (await RoleManagementService.GetActiveRolesAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading roles: {ex.Message}";
        }
    }

    private void ToggleRole(string roleId, bool isSelected)
    {
        if (isSelected)
        {
            if (!createUserDto.RoleIds.Contains(roleId))
            {
                createUserDto.RoleIds.Add(roleId);
            }
        }
        else
        {
            createUserDto.RoleIds.Remove(roleId);
        }
    }

    private async Task CreateNewUser()
    {
        try
        {
            isCreating = true;
            errorMessage = string.Empty;

            var result = await UserManagementService.CreateUserAsync(createUserDto, "System"); // In real app, use current user
            
            // Navigate back to user list with success message
            Navigation.NavigateTo("/admin/users?created=true");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/users");
    }
}