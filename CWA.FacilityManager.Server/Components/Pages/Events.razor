@page "/events"
@rendermode InteractiveServer
@using CWA.FacilityManager.Domain.Models
@using CWA.FacilityManager.Application.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject IEventService EventService
@inject IRoomService RoomService
@inject IBuildingService BuildingService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Events Management</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="container-fluid">
            <!-- Header Section -->
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h2">
                            <i class="fas fa-calendar-alt me-2"></i>Events Management
                        </h1>
                        <div class="btn-group">
                            <button class="btn btn-primary btn-lg" @onclick="ShowAddEventModal" type="button">
                                <i class="fas fa-plus me-2"></i> Add New Event
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Total Events</h6>
                                    <h3 class="mb-0">@(events?.Count() ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-calendar-alt fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Upcoming Events</h6>
                                    <h3 class="mb-0">@(upcomingEvents?.Count() ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-clock fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Confirmed Events</h6>
                                    <h3 class="mb-0">@(events?.Count(e => e.IsConfirmed) ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-check-circle fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="card-title">Total Attendees</h6>
                                    <h3 class="mb-0">@(events?.Sum(e => e.ExpectedAttendees) ?? 0)</h3>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-users fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Messages -->
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="row mb-3">
                    <div class="col-12">
                        <div class="alert @(statusMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                            <i class="fas @(statusMessageType == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                            @statusMessage
                            <button type="button" class="btn-close" @onclick="ClearStatusMessage"></button>
                        </div>
                    </div>
                </div>
            }

            <!-- Filter Section -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Filter Events</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">From Date</label>
                                    <input type="date" class="form-control" @bind="filterStartDate" @bind:after="FilterEvents" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">To Date</label>
                                    <input type="date" class="form-control" @bind="filterEndDate" @bind:after="FilterEvents" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Quick Filters</h6>
                            <div class="btn-group w-100" role="group">
                                <button type="button" class="btn @(currentFilter == "all" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetFilter("all")'>All</button>
                                <button type="button" class="btn @(currentFilter == "upcoming" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetFilter("upcoming")'>Upcoming</button>
                                <button type="button" class="btn @(currentFilter == "today" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetFilter("today")'>Today</button>
                                <button type="button" class="btn @(currentFilter == "confirmed" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetFilter("confirmed")'>Confirmed</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Events Grid -->
            <div class="row">
                @if (filteredEvents == null)
                {
                    <div class="col-12 text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (!filteredEvents.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            <div class="mb-3">
                                <i class="fas fa-calendar-alt fa-4x text-muted"></i>
                            </div>
                            <h4>No Events Available</h4>
                            <p>Start by adding your first event to the system!</p>
                            <button class="btn btn-primary btn-lg" @onclick="ShowAddEventModal" type="button">
                                <i class="fas fa-plus me-2"></i> Add Your First Event
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var eventItem in filteredEvents.OrderBy(e => e.StartDateTime))
                    {
                        <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                            <div class="card h-100 event-card @(eventItem.IsConfirmed ? "confirmed-event" : "pending-event")">
                                <div class="card-header d-flex justify-content-between align-items-center @(eventItem.IsConfirmed ? "bg-success" : "bg-warning") text-white">
                                    <h6 class="card-title mb-0">
                                        @eventItem.Title
                                    </h6>
                                    <div class="dropdown">
                                        <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li><button class="dropdown-item" @onclick="() => EditEvent(eventItem)" type="button">
                                                <i class="fas fa-edit"></i> Edit
                                            </button></li>
                                            <li><button class="dropdown-item" @onclick="() => ToggleConfirmation(eventItem)" type="button">
                                                <i class="fas @(eventItem.IsConfirmed ? "fa-times-circle" : "fa-check-circle")"></i> 
                                                @(eventItem.IsConfirmed ? "Unconfirm" : "Confirm")
                                            </button></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><button class="dropdown-item text-danger" @onclick="() => DeleteEvent(eventItem)" type="button">
                                                <i class="fas fa-trash"></i> Delete
                                            </button></li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="event-info">
                                        <p class="mb-2">
                                            <i class="fas @GetEventTypeIcon(eventItem.Type) text-primary me-2"></i>
                                            <strong>Type:</strong> @eventItem.Type
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-building text-info me-2"></i>
                                            <strong>Location:</strong> @eventItem.Room.Building.Name - @eventItem.Room.Name
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-calendar text-success me-2"></i>
                                            <strong>Start:</strong> @eventItem.StartDateTime.ToString("MMM dd, yyyy HH:mm")
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-calendar-check text-warning me-2"></i>
                                            <strong>End:</strong> @eventItem.EndDateTime.ToString("MMM dd, yyyy HH:mm")
                                        </p>
                                        @if (!string.IsNullOrEmpty(eventItem.Organizer))
                                        {
                                            <p class="mb-2">
                                                <i class="fas fa-user text-secondary me-2"></i>
                                                <strong>Organizer:</strong> @eventItem.Organizer
                                            </p>
                                        }
                                        <p class="mb-2">
                                            <i class="fas fa-users text-info me-2"></i>
                                            <strong>Expected Attendees:</strong> @eventItem.ExpectedAttendees
                                        </p>
                                        @if (!string.IsNullOrEmpty(eventItem.Description))
                                        {
                                            <p class="text-muted small">
                                                <i class="fas fa-info-circle me-1"></i>
                                                @((eventItem.Description.Length > 100) ? eventItem.Description.Substring(0, 100) + "..." : eventItem.Description)
                                            </p>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            Created: @eventItem.CreatedAt.ToString("MMM dd, yyyy")
                                        </small>
                                        <span class="badge @(eventItem.IsConfirmed ? "bg-success" : "bg-warning")">
                                            @(eventItem.IsConfirmed ? "Confirmed" : "Pending")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Add/Edit Event Modal -->
        @if (showEventModal)
        {
            <!-- Modal Backdrop -->
            <div class="modal-backdrop fade show" @onclick="CloseModal"></div>
            
            <!-- Modal Dialog -->
            <div class="modal fade show d-block" tabindex="-1" style="z-index: 1060;">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="fas @(isEditMode ? "fa-edit" : "fa-plus") me-2"></i>
                                @(isEditMode ? "Edit Event" : "Add New Event")
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseModal" aria-label="Close"></button>
                        </div>
                        
                        <EditForm Model="eventModel" OnValidSubmit="SaveEvent" Context="editContext">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <ValidationSummary class="text-danger mb-3" />
                                
                                <!-- Event Title -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-heading me-1"></i>Event Title <span class="text-danger">*</span>
                                    </label>
                                    <InputText class="form-control form-control-lg" @bind-Value="eventModel.Title" 
                                               placeholder="Enter event title" />
                                    <ValidationMessage For="() => eventModel.Title" class="text-danger" />
                                </div>

                                <!-- Event Type -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-tags me-1"></i>Event Type <span class="text-danger">*</span>
                                    </label>
                                    <InputSelect class="form-select form-select-lg" @bind-Value="eventModel.Type">
                                        <option value="@EventType.Meeting">Meeting</option>
                                        <option value="@EventType.Course">Course</option>
                                        <option value="@EventType.Conference">Conference</option>
                                        <option value="@EventType.Training">Training</option>
                                        <option value="@EventType.Workshop">Workshop</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => eventModel.Type" class="text-danger" />
                                </div>

                                <!-- Room Selection -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-door-open me-1"></i>Room <span class="text-danger">*</span>
                                    </label>
                                    <InputSelect class="form-select form-select-lg" @bind-Value="eventModel.RoomId" @bind-Value:after="OnRoomChanged">
                                        <option value="0">Select a room...</option>
                                        @if (rooms != null)
                                        {
                                            @foreach (var room in rooms)
                                            {
                                                <option value="@room.Id">@room.Building.Name - @room.Name (Capacity: @room.Capacity)</option>
                                            }
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => eventModel.RoomId" class="text-danger" />
                                    @if (selectedRoomCapacity > 0)
                                    {
                                        <div class="form-text">Selected room capacity: @selectedRoomCapacity people</div>
                                    }
                                </div>

                                <!-- Date and Time Section -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-calendar me-1"></i>Start Date & Time <span class="text-danger">*</span>
                                            </label>
                                            <InputDate class="form-control mb-2" @bind-Value="startDate" />
                                            <InputText class="form-control" @bind-Value="startTime" type="time" />
                                            <ValidationMessage For="() => eventModel.StartDateTime" class="text-danger" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-calendar-check me-1"></i>End Date & Time <span class="text-danger">*</span>
                                            </label>
                                            <InputDate class="form-control mb-2" @bind-Value="endDate" />
                                            <InputText class="form-control" @bind-Value="endTime" type="time" />
                                            <ValidationMessage For="() => eventModel.EndDateTime" class="text-danger" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Organizer and Expected Attendees -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-user me-1"></i>Organizer
                                            </label>
                                            <InputText class="form-control" @bind-Value="eventModel.Organizer" 
                                                       placeholder="Event organizer name" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">
                                                <i class="fas fa-users me-1"></i>Expected Attendees
                                            </label>
                                            <InputNumber class="form-control" @bind-Value="eventModel.ExpectedAttendees" 
                                                         min="1" placeholder="Number of attendees" />
                                            @if (selectedRoomCapacity > 0 && eventModel.ExpectedAttendees > selectedRoomCapacity)
                                            {
                                                <div class="text-warning small">
                                                    <i class="fas fa-exclamation-triangle"></i> 
                                                    Attendees exceed room capacity (@selectedRoomCapacity)
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Contact Email -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-envelope me-1"></i>Contact Email
                                    </label>
                                    <InputText class="form-control" @bind-Value="eventModel.ContactEmail" 
                                               type="email" placeholder="contact@example.com" />
                                    <ValidationMessage For="() => eventModel.ContactEmail" class="text-danger" />
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-align-left me-1"></i>Description
                                    </label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="eventModel.Description" 
                                                   placeholder="Event description, agenda, requirements..." />
                                </div>

                                <!-- Confirmation Status -->
                                <div class="mb-3">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="eventModel.IsConfirmed" id="isConfirmed" />
                                        <label class="form-check-label fw-bold" for="isConfirmed">
                                            <i class="fas fa-check-circle me-1"></i>Event Confirmed
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                                    <i class="fas fa-times me-1"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                    @if (isProcessing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="fas @(isEditMode ? "fa-save" : "fa-plus") me-1"></i>
                                    @(isEditMode ? "Update Event" : "Create Event")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="text-center mt-5">
                        <i class="fas fa-lock fa-4x text-muted mb-4"></i>
                        <h2>Access Restricted</h2>
                        <p class="text-muted">You need to be logged in to access the events management system.</p>
                        <a href="/Account/Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Event>? events;
    private IEnumerable<Event>? upcomingEvents;
    private IEnumerable<Event>? filteredEvents;
    private IEnumerable<Room>? rooms;
    private bool showEventModal = false;
    private bool isEditMode = false;
    private bool isProcessing = false;
    private Event eventModel = new Event();
    private string statusMessage = string.Empty;
    private string statusMessageType = "success";
    private string currentFilter = "all";
    private DateTime filterStartDate = DateTime.Today;
    private DateTime filterEndDate = DateTime.Today.AddMonths(1);
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today;
    private string startTime = "09:00";
    private string endTime = "10:00";
    private int selectedRoomCapacity = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            events = await EventService.GetAllEventsAsync();
            upcomingEvents = await EventService.GetUpcomingEventsAsync();
            rooms = await RoomService.GetAllRoomsAsync();
            
            ApplyCurrentFilter();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error loading data: {ex.Message}", "error");
        }
    }

    private void ApplyCurrentFilter()
    {
        if (events == null) return;

        filteredEvents = currentFilter switch
        {
            "upcoming" => events.Where(e => e.StartDateTime >= DateTime.Now),
            "today" => events.Where(e => e.StartDateTime.Date == DateTime.Today),
            "confirmed" => events.Where(e => e.IsConfirmed),
            _ => events
        };
    }

    private void SetFilter(string filter)
    {
        currentFilter = filter;
        ApplyCurrentFilter();
        StateHasChanged();
    }

    private async Task FilterEvents()
    {
        try
        {
            events = await EventService.GetEventsByDateRangeAsync(filterStartDate, filterEndDate.AddDays(1));
            ApplyCurrentFilter();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error filtering events: {ex.Message}", "error");
        }
    }

    private void ShowAddEventModal()
    {
        eventModel = new Event
        {
            Id = 0,
            Type = EventType.Meeting,
            StartDateTime = DateTime.Today.AddHours(9),
            EndDateTime = DateTime.Today.AddHours(10),
            ExpectedAttendees = 1,
            IsConfirmed = false,
            CreatedAt = DateTime.UtcNow
        };
        
        startDate = DateTime.Today;
        endDate = DateTime.Today;
        startTime = "09:00";
        endTime = "10:00";
        selectedRoomCapacity = 0;
        
        isEditMode = false;
        showEventModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void EditEvent(Event eventItem)
    {
        eventModel = new Event
        {
            Id = eventItem.Id,
            Title = eventItem.Title,
            Description = eventItem.Description,
            Type = eventItem.Type,
            StartDateTime = eventItem.StartDateTime,
            EndDateTime = eventItem.EndDateTime,
            Organizer = eventItem.Organizer,
            ContactEmail = eventItem.ContactEmail,
            ExpectedAttendees = eventItem.ExpectedAttendees,
            IsConfirmed = eventItem.IsConfirmed,
            RoomId = eventItem.RoomId,
            CreatedAt = eventItem.CreatedAt
        };

        startDate = eventItem.StartDateTime.Date;
        endDate = eventItem.EndDateTime.Date;
        startTime = eventItem.StartDateTime.ToString("HH:mm");
        endTime = eventItem.EndDateTime.ToString("HH:mm");
        
        OnRoomChanged();
        
        isEditMode = true;
        showEventModal = true;
        ClearStatusMessage();
        StateHasChanged();
    }

    private void CloseModal()
    {
        showEventModal = false;
        eventModel = new Event();
        selectedRoomCapacity = 0;
        isProcessing = false;
        isEditMode = false;
        StateHasChanged();
    }

    private void OnRoomChanged()
    {
        if (eventModel.RoomId > 0 && rooms != null)
        {
            var selectedRoom = rooms.FirstOrDefault(r => r.Id == eventModel.RoomId);
            selectedRoomCapacity = selectedRoom?.Capacity ?? 0;
            StateHasChanged();
        }
        else
        {
            selectedRoomCapacity = 0;
        }
    }

    private async Task SaveEvent()
    {
        if (string.IsNullOrWhiteSpace(eventModel.Title))
        {
            ShowStatusMessage("Event title is required.", "error");
            return;
        }

        if (eventModel.RoomId <= 0)
        {
            ShowStatusMessage("Please select a room.", "error");
            return;
        }

        // Combine date and time
        if (!TimeSpan.TryParse(startTime, out var startTimeSpan))
        {
            ShowStatusMessage("Invalid start time format.", "error");
            return;
        }

        if (!TimeSpan.TryParse(endTime, out var endTimeSpan))
        {
            ShowStatusMessage("Invalid end time format.", "error");
            return;
        }

        eventModel.StartDateTime = startDate.Add(startTimeSpan);
        eventModel.EndDateTime = endDate.Add(endTimeSpan);

        if (eventModel.StartDateTime >= eventModel.EndDateTime)
        {
            ShowStatusMessage("End time must be after start time.", "error");
            return;
        }

        isProcessing = true;
        StateHasChanged();

        try
        {
            // Check room availability
            var isAvailable = await EventService.IsRoomAvailableAsync(
                eventModel.RoomId, 
                eventModel.StartDateTime, 
                eventModel.EndDateTime, 
                isEditMode ? eventModel.Id : null);

            if (!isAvailable)
            {
                ShowStatusMessage("The selected room is not available during this time period.", "error");
                return;
            }

            // Set created by user if creating new event
            if (!isEditMode)
            {
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                eventModel.CreatedById = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            }

            if (isEditMode)
            {
                await EventService.UpdateEventAsync(eventModel);
                ShowStatusMessage($"Event '{eventModel.Title}' updated successfully!", "success");
            }
            else
            {
                await EventService.CreateEventAsync(eventModel);
                ShowStatusMessage($"Event '{eventModel.Title}' created successfully!", "success");
            }

            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error saving event: {ex.Message}", "error");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteEvent(Event eventItem)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{eventItem.Title}'? This action cannot be undone."))
        {
            try
            {
                var result = await EventService.DeleteEventAsync(eventItem.Id);
                if (result)
                {
                    ShowStatusMessage($"Event '{eventItem.Title}' deleted successfully!", "success");
                    await LoadData();
                }
                else
                {
                    ShowStatusMessage("Failed to delete event. Event not found.", "error");
                }
            }
            catch (Exception ex)
            {
                ShowStatusMessage($"Error deleting event: {ex.Message}", "error");
            }
        }
    }

    private async Task ToggleConfirmation(Event eventItem)
    {
        try
        {
            // Create a new event object with only the necessary properties for update
            var eventToUpdate = new Event
            {
                Id = eventItem.Id,
                Title = eventItem.Title,
                Description = eventItem.Description,
                Type = eventItem.Type,
                StartDateTime = eventItem.StartDateTime,
                EndDateTime = eventItem.EndDateTime,
                Organizer = eventItem.Organizer,
                ContactEmail = eventItem.ContactEmail,
                ExpectedAttendees = eventItem.ExpectedAttendees,
                IsConfirmed = !eventItem.IsConfirmed, // Toggle the confirmation status
                RoomId = eventItem.RoomId,
                CreatedAt = eventItem.CreatedAt,
                CreatedById = eventItem.CreatedById
            };

            await EventService.UpdateEventAsync(eventToUpdate);
            
            var status = eventToUpdate.IsConfirmed ? "confirmed" : "unconfirmed";
            ShowStatusMessage($"Event '{eventItem.Title}' has been {status}!", "success");
            
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowStatusMessage($"Error updating event status: {ex.Message}", "error");
        }
    }

    private void ShowStatusMessage(string message, string type)
    {
        statusMessage = message;
        statusMessageType = type;
        StateHasChanged();

        if (type == "success")
        {
            Task.Delay(5000).ContinueWith(task =>
            {
                InvokeAsync(() =>
                {
                    ClearStatusMessage();
                    StateHasChanged();
                });
            });
        }
    }

    private void ClearStatusMessage()
    {
        statusMessage = string.Empty;
        StateHasChanged();
    }

    private string GetEventTypeIcon(EventType type)
    {
        return type switch
        {
            EventType.Meeting => "fa-handshake",
            EventType.Course => "fa-graduation-cap",
            EventType.Conference => "fa-microphone",
            EventType.Training => "fa-dumbbell",
            EventType.Workshop => "fa-tools",
            _ => "fa-calendar"
        };
    }
}

