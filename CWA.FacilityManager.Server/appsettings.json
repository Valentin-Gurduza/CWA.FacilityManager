{
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlexpress,1433;Database=cwa-facilitymanager-mssql;User Id=sa;Password=ChangePassword123!;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "RequireConfirmedAccount": true
  },
  "Smtp": {
    "From": "CWA Facility Manager",
    "EnableSsl": true,
    "Host": "",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "RequiresAuthentication": true,
    "UseDefaultCredentials": false,
    "SystemErrorRecipients": ""
  },
  "Application": {
    "Name": "CWA Facility Manager",
    "Version": "1.0.0",
    "SupportEmail": "support@facilitymanager.local"
  },
  "Security": {
    "PasswordPolicy": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": false
    },
    "Lockout": {
      "DefaultLockoutTimeSpanMinutes": 15,
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": true
    }
  },
  "Caching": {
    "DefaultExpirationMinutes": 5,
    "RoomsExpirationMinutes": 2,
    "BuildingsExpirationMinutes": 10
  }
}
